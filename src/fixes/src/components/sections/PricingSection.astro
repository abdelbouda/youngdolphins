---
import Container from '../ui/Container.astro';
import { t, tObject } from '../../i18n/ui';
import type { Locale } from '../../i18n/types';

interface Props {
  locale?: Locale;
}

const { locale = 'nl' } = Astro.props;

const title = await t(locale, 'pricing.title');
const subtitle = await t(locale, 'pricing.subtitle');
const cta = await t(locale, 'pricing.cta');

const starter = {
  name: await t(locale, 'pricing.packages.starter.name'),
  price: '€15',
  priceUnit: await t(locale, 'pricing.packages.starter.price_unit'),
  description: await t(locale, 'pricing.packages.starter.description'),
  features: await tObject(locale, 'pricing.packages.starter.features')
};

const progress = {
  name: await t(locale, 'pricing.packages.progress.name'),
  badge: await t(locale, 'pricing.packages.progress.badge'),
  price: '€55',
  priceUnit: await t(locale, 'pricing.packages.progress.price_unit'),
  description: await t(locale, 'pricing.packages.progress.description'),
  features: await tObject(locale, 'pricing.packages.progress.features')
};

const priv = {
  name: await t(locale, 'pricing.packages.private.name'),
  price: '€35',
  priceUnit: await t(locale, 'pricing.packages.private.price_unit'),
  description: await t(locale, 'pricing.packages.private.description'),
  features: await tObject(locale, 'pricing.packages.private.features')
};

const compareTitle = await t(locale, 'pricing.compare.title');
const compareFeature = await t(locale, 'pricing.compare.feature');
const compareRows = {
  lessons: await t(locale, 'pricing.compare.rows.lessons'),
  report: await t(locale, 'pricing.compare.rows.report'),
  personal: await t(locale, 'pricing.compare.rows.personal'),
  access: await t(locale, 'pricing.compare.rows.access')
};
---

<section id="pricing" class="py-16 sm:py-24 bg-[#F7FBFF]" aria-labelledby="pricing-title">
  <Container>

    <div class="text-center mb-10 sm:mb-14 px-4">
      <h2 id="pricing-title" class="text-2xl sm:text-3xl md:text-4xl font-bold text-[#001F3F] mb-3">
        {title}
      </h2>
      <p class="text-gray-600 max-w-2xl mx-auto text-sm sm:text-base">
        {subtitle}
      </p>
    </div>

    <!-- Pricing Cards: 1 kolom mobiel, 3 kolommen desktop -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 sm:gap-8 max-w-5xl mx-auto mb-16 px-4">

      <!-- Starter -->
      <div class="bg-white border border-[#E1EEF7] rounded-2xl p-6 sm:p-8 shadow-sm hover:shadow-md transition-all flex flex-col">
        <h3 class="text-xl font-semibold text-[#001F3F] mb-2 text-center">{starter.name}</h3>
        <div class="flex items-baseline justify-center mb-3">
          <span class="text-4xl font-bold text-[#001F3F]">{starter.price}</span>
          <span class="text-base text-gray-500 ml-1">{starter.priceUnit}</span>
        </div>
        <p class="text-gray-600 text-sm mb-5 text-center">{starter.description}</p>
        <ul class="space-y-2 mb-6 text-sm text-gray-700 flex-1">
          {starter.features.map(f => (
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-[#00AEEF] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              {f}
            </li>
          ))}
        </ul>
        <a href="/#hero" class="cta-primary w-full text-center mt-auto">{cta}</a>
      </div>

      <!-- Progress+ (featured) -->
      <div class="bg-white border-2 border-[#00AEEF] rounded-2xl p-6 sm:p-8 shadow-lg relative flex flex-col md:scale-[1.02]">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2">
          <span class="px-3 py-1 text-xs bg-[#00AEEF] text-white rounded-full font-semibold whitespace-nowrap">
            {progress.badge}
          </span>
        </div>
        <h3 class="text-xl font-semibold text-[#001F3F] mb-2 text-center">{progress.name}</h3>
        <div class="flex items-baseline justify-center mb-3">
          <span class="text-4xl font-bold text-[#001F3F]">{progress.price}</span>
          <span class="text-base text-gray-500 ml-1">{progress.priceUnit}</span>
        </div>
        <p class="text-gray-600 text-sm mb-5 text-center">{progress.description}</p>
        <ul class="space-y-2 mb-6 text-sm text-gray-700 flex-1">
          {progress.features.map(f => (
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-[#00AEEF] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              {f}
            </li>
          ))}
        </ul>
        <a href="/#hero" class="cta-primary w-full text-center mt-auto">{cta}</a>
      </div>

      <!-- Privé -->
      <div class="bg-white border border-[#E1EEF7] rounded-2xl p-6 sm:p-8 shadow-sm hover:shadow-md transition-all flex flex-col">
        <h3 class="text-xl font-semibold text-[#001F3F] mb-2 text-center">{priv.name}</h3>
        <div class="flex items-baseline justify-center mb-3">
          <span class="text-4xl font-bold text-[#001F3F]">{priv.price}</span>
          <span class="text-base text-gray-500 ml-1">{priv.priceUnit}</span>
        </div>
        <p class="text-gray-600 text-sm mb-5 text-center">{priv.description}</p>
        <ul class="space-y-2 mb-6 text-sm text-gray-700 flex-1">
          {priv.features.map(f => (
            <li class="flex items-center gap-2">
              <svg class="w-4 h-4 text-[#00AEEF] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              {f}
            </li>
          ))}
        </ul>
        <a href="/#hero" class="cta-primary w-full text-center mt-auto">{cta}</a>
      </div>

    </div>

    <!-- Vergelijkingstabel: horizontaal scrollbaar op mobile -->
    <div class="max-w-3xl mx-auto px-4">
      <h3 class="text-xl sm:text-2xl font-semibold text-[#001F3F] mb-6 text-center">
        {compareTitle}
      </h3>

      <!-- Scrollable wrapper op mobile -->
      <div class="overflow-x-auto -mx-4 sm:mx-0 rounded-xl border border-[#E1EEF7]">
        <table class="w-full text-sm text-gray-700 bg-white" style="min-width: 400px;">
          <thead>
            <tr class="border-b border-[#E1EEF7] bg-[#F7FBFF]">
              <th class="text-left px-4 py-3 font-semibold text-[#001F3F]">{compareFeature}</th>
              <th class="text-center px-4 py-3 font-semibold text-[#001F3F]">{starter.name}</th>
              <th class="text-center px-4 py-3 font-semibold text-[#00AEEF]">{progress.name}</th>
              <th class="text-center px-4 py-3 font-semibold text-[#001F3F]">{priv.name}</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-3">{compareRows.lessons}</td>
              <td class="text-center px-4 py-3">1</td>
              <td class="text-center px-4 py-3 font-semibold text-[#00AEEF]">2</td>
              <td class="text-center px-4 py-3">1</td>
            </tr>
            <tr class="border-b border-gray-100 bg-gray-50/50">
              <td class="px-4 py-3">{compareRows.report}</td>
              <td class="text-center px-4 py-3 text-gray-400">–</td>
              <td class="text-center px-4 py-3 text-[#00AEEF]">✓</td>
              <td class="text-center px-4 py-3 text-[#00AEEF]">✓</td>
            </tr>
            <tr class="border-b border-gray-100">
              <td class="px-4 py-3">{compareRows.personal}</td>
              <td class="text-center px-4 py-3 text-gray-400">–</td>
              <td class="text-center px-4 py-3 text-[#00AEEF]">✓</td>
              <td class="text-center px-4 py-3 text-[#00AEEF]">✓✓</td>
            </tr>
            <tr>
              <td class="px-4 py-3">{compareRows.access}</td>
              <td class="text-center px-4 py-3 text-gray-400">–</td>
              <td class="text-center px-4 py-3 text-[#00AEEF]">✓</td>
              <td class="text-center px-4 py-3 text-[#00AEEF]">✓</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>

  </Container>
</section>
