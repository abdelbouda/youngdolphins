---
import Container from '../ui/Container.astro';
import { t } from '../../i18n/ui';
import type { Locale } from '../../i18n/types';
import heroImg from '../../assets/hero-kids.webp';

interface Props {
  locale?: Locale;
}

const { locale = 'nl' } = Astro.props;

const title = await t(locale, 'hero.title');
const subtitle = await t(locale, 'hero.subtitle');
const ctaPrimary = await t(locale, 'hero.cta_primary');
const ctaSecondary = await t(locale, 'hero.cta_secondary');
const statDiplomas = await t(locale, 'hero.stats.diplomas');
const statSuccess = await t(locale, 'hero.stats.success');
const statRating = await t(locale, 'hero.stats.rating');
const continueReading = await t(locale, 'hero.continue_reading');
---

<section
  id="hero"
  class="relative pt-24 pb-16 sm:pt-32 sm:pb-20 bg-gradient-to-b from-[#E6F4FF] to-white overflow-hidden"
>
  <!-- Decorative bubbles -->
  <div class="absolute inset-0 opacity-30 pointer-events-none" aria-hidden="true">
    <div class="absolute top-10 left-10 w-32 h-32 sm:w-40 sm:h-40 bg-[#00AEEF]/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-10 w-44 h-44 sm:w-56 sm:h-56 bg-[#001F3F]/20 rounded-full blur-3xl"></div>
  </div>

  <Container class="relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">

      <!-- LEFT COLUMN: text -->
      <div class="text-center lg:text-left space-y-5 sm:space-y-6 hero-fade px-2 sm:px-4">

        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold leading-tight text-[#001F3F]">
          {title}
        </h1>

        <p class="text-base sm:text-lg text-gray-700 max-w-xl mx-auto lg:mx-0 leading-relaxed">
          {subtitle}
        </p>

        <!-- CTA Buttons: stacked on mobile, side-by-side on sm+ -->
        <div class="flex flex-col sm:flex-row gap-3 pt-2 justify-center lg:justify-start">
          <a
            href="/#pricing"
            class="cta-primary w-full sm:w-auto text-center"
          >
            {ctaPrimary}
          </a>
          <a
            href="/#faq"
            class="cta-secondary w-full sm:w-auto text-center"
          >
            {ctaSecondary}
          </a>
        </div>

        <!-- Stats: 3 kolommen, grotere tekst op mobile -->
        <div class="grid grid-cols-3 gap-3 sm:gap-6 pt-4 max-w-xs sm:max-w-md mx-auto lg:mx-0">

          <div class="text-center lg:text-left">
            <div class="text-2xl sm:text-3xl font-bold text-[#001F3F]">1200+</div>
            <div class="text-[10px] sm:text-xs text-gray-600 leading-tight mt-0.5">{statDiplomas}</div>
          </div>

          <div class="text-center lg:text-left">
            <div class="text-2xl sm:text-3xl font-bold text-[#001F3F]">98%</div>
            <div class="text-[10px] sm:text-xs text-gray-600 leading-tight mt-0.5">{statSuccess}</div>
          </div>

          <div class="text-center lg:text-left">
            <div class="text-2xl sm:text-3xl font-bold text-[#001F3F]">4.9★</div>
            <div class="text-[10px] sm:text-xs text-gray-600 leading-tight mt-0.5">{statRating}</div>
          </div>

        </div>
      </div>

      <!-- RIGHT COLUMN: afbeelding -->
      <div class="flex justify-center items-center hero-fade px-4 sm:px-8 lg:px-4">
        <img
          src={heroImg.src}
          alt={locale === 'en' ? 'Children learning to swim at Young Dolphins Amsterdam' : 'Kinderen leren zwemmen bij Young Dolphins Amsterdam'}
          class="w-full max-w-[280px] sm:max-w-sm md:max-w-md lg:max-w-full h-auto rounded-2xl shadow-xl object-cover"
          loading="eager"
          fetchpriority="high"
          width="600"
          height="450"
        />
      </div>

    </div>
  </Container>

  <!-- Scroll indicator - alleen op grotere schermen -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-10 hero-fade hidden sm:flex">
    <a href="#features" class="group flex flex-col items-center gap-1" aria-label={continueReading}>
      <span class="text-xs text-gray-500 font-medium">{continueReading}</span>
      <svg class="w-4 h-4 text-gray-400 group-hover:text-[#00AEEF] transition animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
      </svg>
    </a>
  </div>
</section>

<style is:global>
  .hero-fade {
    opacity: 0;
    transform: translateY(12px);
    animation: fadeUp 0.7s ease forwards;
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .cta-primary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: #001F3F;
    color: #ffffff !important;
    font-weight: 600;
    padding: 0.875rem 1.75rem;
    border-radius: 0.5rem;
    transition: all 0.2s ease;
    box-shadow: 0 2px 6px rgba(0,0,0,0.15);
    font-size: 0.9375rem;
    /* Minimum touch target */
    min-height: 48px;
    text-decoration: none !important;
  }

  .cta-primary:hover {
    background-color: #003366;
    transform: scale(1.02);
    text-decoration: none !important;
  }

  .cta-secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: transparent;
    color: #001F3F !important;
    font-weight: 600;
    padding: 0.875rem 1.75rem;
    border-radius: 0.5rem;
    border: 2px solid #001F3F;
    transition: all 0.2s ease;
    font-size: 0.9375rem;
    min-height: 48px;
    text-decoration: none !important;
  }

  .cta-secondary:hover {
    background-color: #001F3F;
    color: #ffffff !important;
    text-decoration: none !important;
  }
</style>
