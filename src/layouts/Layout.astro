---
import '../styles/global.css';
import Header from '../components/ui/Header.astro';
import type { Locale } from '../i18n/types';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  locale?: Locale;
}

const {
  title = "Young Dolphins – Zwemschool Amsterdam",
  description = "Zwemlessen voor kinderen in Amsterdam. Veilig leren zwemmen met plezier, vertrouwen en persoonlijke aandacht. A-, B- en C-diploma's.",
  image = "/og-image.jpg",
  canonical,
  noindex = false,
  locale = 'nl'
} = Astro.props;

const htmlLang = locale === 'en' ? 'en' : 'nl';
const siteUrl = Astro.site || 'https://youngdolphins.vercel.app';
const canonicalURL = canonical || new URL(Astro.url.pathname, siteUrl);
const imageURL = new URL(image, siteUrl);

// hreflang alternates
const currentPath = Astro.url.pathname.replace(/^\/(nl|en)/, '') || '/';
const nlURL = new URL(`/nl${currentPath}`, siteUrl);
const enURL = new URL(`/en${currentPath}`, siteUrl);

const titleEn = "Young Dolphins – Swimming School Amsterdam";
const descriptionEn = "Swimming lessons for children in Amsterdam. Learn to swim safely and joyfully. A, B and C certificates.";
const pageTitle = locale === 'en' ? titleEn : title;
const pageDescription = locale === 'en' ? descriptionEn : description;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <!-- Critically important for mobile -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#001F3F" />

    <!-- SEO -->
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {!noindex && <meta name="robots" content="index, follow, max-image-preview:large" />}

    <!-- hreflang for bilingual SEO -->
    <link rel="alternate" hreflang="nl" href={nlURL} />
    <link rel="alternate" hreflang="en" href={enURL} />
    <link rel="alternate" hreflang="x-default" href={nlURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Young Dolphins" />
    <meta property="og:locale" content={locale === 'en' ? 'en_US' : 'nl_NL'} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={imageURL} />

    <!-- Performance: preconnect fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Non-render-blocking font load -->
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" /></noscript>
    <!-- Preload logo (LCP on mobile) and hero image -->
    <link rel="preload" as="image" href="/yd-logo.webp" fetchpriority="high" />
    <link rel="preload" as="image" href="/hero-kids.webp" />

    <!-- Structured Data: LocalBusiness -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SportsActivityLocation",
      "name": "Young Dolphins",
      "url": siteUrl.toString(),
      "logo": new URL("/favicon.png", siteUrl).toString(),
      "image": imageURL.toString(),
      "description": locale === 'en'
        ? "Professional swimming lessons for children in Amsterdam."
        : "Professionele zwemlessen voor kinderen in Amsterdam.",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Amsterdam",
        "addressCountry": "NL"
      },
      "telephone": "+31628421354",
      "email": "info@youngdolphins.nl",
      "sameAs": ["https://wa.me/31628421354"],
      "openingHours": "Mo-Fr 09:00-18:00",
      "priceRange": "€15-€55",
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+31628421354",
        "contactType": "customer service",
        "areaServed": "Amsterdam",
        "availableLanguage": ["Dutch", "English"]
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "120"
      }
    })} />
  </head>

  <body class="font-inter bg-white text-gray-900 antialiased pt-16 md:pt-20">
    <Header locale={locale} />

    <main id="main-content">
      <slot />
    </main>

    <footer class="mt-20 pt-12 pb-8 text-sm text-gray-500 border-t border-gray-100 bg-white">
      <div class="max-w-7xl mx-auto px-4">
        <div class="flex flex-col items-center gap-4 mb-8">
          <img src="/yd-logo.webp" alt="Young Dolphins logo" width="180" height="180" style="height: 90px; width: auto; object-fit: contain;" loading="lazy" />
          <p class="text-base font-semibold text-[#001F3F]">Young Dolphins – Zwemschool Amsterdam</p>
          <div class="flex flex-wrap justify-center gap-4 text-sm text-gray-500">
            <a href="https://wa.me/31628421354" class="hover:text-[#001F3F] transition-colors">📞 06-28421354</a>
            <a href="mailto:info@youngdolphins.nl" class="hover:text-[#001F3F] transition-colors">✉️ info@youngdolphins.nl</a>
          </div>
        </div>
        <div class="border-t border-gray-100 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs">
          <span>© {new Date().getFullYear()} Young Dolphins – Zwemschool Amsterdam</span>
          <div class="flex gap-4">
            <a href={`/${locale}/privacy`} class="hover:text-gray-700 transition-colors">Privacy</a>
            <a href={`/${locale}/terms`} class="hover:text-gray-700 transition-colors">{locale === 'en' ? 'Terms' : 'Voorwaarden'}</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
    /* Prevent horizontal scroll on mobile */
    overflow-x: hidden;
  }

  body {
    font-family: 'Inter', sans-serif;
    background-color: #ffffff;
    color: #111827;
    /* Prevent horizontal scroll on mobile */
    overflow-x: hidden;
  }

  /* Better tap targets on mobile */
  a, button {
    -webkit-tap-highlight-color: transparent;
  }

  /* Ensure images don't overflow */
  img {
    max-width: 100%;
    height: auto;
  }
</style>
