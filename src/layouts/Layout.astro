---
import '../styles/global.css';
import Header from '../components/ui/Header.astro';
import type { Locale } from '../i18n/types';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonical?: string;
  noindex?: boolean;
  locale?: Locale;
}

const {
  title = "Young Dolphins – Zwemschool Amsterdam",
  description = "Zwemlessen voor kinderen in Amsterdam. Veilig leren zwemmen met plezier, vertrouwen en persoonlijke aandacht. A-, B- en C-diploma’s.",
  image = "/og-image.jpg",
  canonical,
  noindex = false,
  locale = 'nl'
} = Astro.props;

const htmlLang = locale === 'en' ? 'en' : 'nl';
const siteUrl = Astro.site || 'https://youngdolphins.vercel.app';
const canonicalURL = canonical || new URL(Astro.url.pathname, siteUrl);
const imageURL = new URL(image, siteUrl);
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageURL} />
    <meta property="og:site_name" content="Young Dolphins" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageURL} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet" />

    <!-- Structured Data: LocalBusiness (100% geldige JSON) -->
    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "SportsActivityLocation",
        "name": "Young Dolphins",
        "image": imageURL.toString(),
        "description": "Professionele zwemlessen voor kinderen in Amsterdam. Veilig, plezierig en met persoonlijke aandacht.",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Amsterdam",
          "addressCountry": "NL"
        },
        "telephone": "+31628421354",
        "email": "info@youngdolphins.nl",
        "sameAs": ["https://wa.me/31628421354"],
        "openingHours": "Mo-Fr 09:00-18:00",
        "contactPoint": {
          "@type": "ContactPoint",
          "telephone": "+31628421354",
          "contactType": "customer service",
          "areaServed": "Amsterdam",
          "availableLanguage": ["Dutch", "English"]
        }
      })}
    </script>

    <!-- FIX: Language Switcher altijd wit -->
    <style is:global>
      header .language-switcher,
      header .language-switcher *,
      header [class*="LanguageSwitcher"],
      header [class*="language-switcher"],
      header [class*="locale"],
      header [class*="lang"] {
        color: #ffffff !important;
        fill: #ffffff !important;
      }
    </style>
  </head>

  <body class="font-inter bg-white text-gray-900 antialiased">

    <!-- HEADER (nu correct geplaatst) -->
    <Header locale={locale} />

    <main id="main-content">
      <slot />
    </main>

    <footer class="mt-20 py-10 text-center text-sm text-gray-500">
      © {new Date().getFullYear()} Young Dolphins – Zwemschool Amsterdam
    </footer>
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Inter', sans-serif;
    background-color: #ffffff;
    color: #111827;
  }

  a {
    color: #004aad;
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  a:visited {
    color: #004aad;
  }
</style>
