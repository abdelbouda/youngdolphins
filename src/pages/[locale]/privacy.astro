---
export async function getStaticPaths() {
  return [
    { params: { locale: 'nl' } },
    { params: { locale: 'en' } },
  ];
}

const { locale } = Astro.params;
import Layout from '../../layouts/Layout.astro';
import Container from '../../components/ui/Container.astro';
import { t } from '../../i18n/utils';

const title = await t(locale, 'privacy.title');
const subtitle = await t(locale, 'privacy.subtitle');
---

<Layout locale={locale} title={title} description={subtitle}>
  <Container class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <div class="prose prose-lg max-w-none">
        <h1 class="text-3xl font-bold text-[#001F3F] mb-8">{title}</h1>
        <p class="text-lg text-gray-600 mb-12">{subtitle}</p>
        
        <div class="space-y-8">
          <section>
            <h2 class="text-2xl font-semibold text-[#001F3F] mb-4">
              {await t(locale, 'privacy.data.title')}
            </h2>
            <p class="text-gray-700 mb-4">
              {await t(locale, 'privacy.data.description')}
            </p>
            
            <h3 class="text-xl font-semibold text-[#001F3F] mb-3">
              {await t(locale, 'privacy.data.collection.title')}
            </h3>
            <p class="text-gray-700 mb-4">
              {await t(locale, 'privacy.data.collection.description')}
            </p>
            
            <h3 class="text-xl font-semibold text-[#001F3F] mb-3">
              {await t(locale, 'privacy.data.usage.title')}
            </h3>
            <p class="text-gray-700 mb-4">
              {await t(locale, 'privacy.data.usage.description')}
            </p>
            
            <h3 class="text-xl font-semibold text-[#001F3F] mb-3">
              {await t(locale, 'privacy.data.sharing.title')}
            </h3>
            <p class="text-gray-700 mb-4">
              {await t(locale, 'privacy.data.sharing.description')}
            </p>
            
            <h3 class="text-xl font-semibold text-[#001F3F] mb-3">
              {await t(locale, 'privacy.data.cookies.title')}
            </h3>
            <p class="text-gray-700 mb-4">
              {await t(locale, 'privacy.data.cookies.description')}
            </p>
            
            <h3 class="text-xl font-semibold text-[#001F3F] mb-3">
              {await t(locale, 'privacy.data.security.title')}
            </h3>
            <p class="text-gray-700 mb-4">
              {await t(locale, 'privacy.data.security.description')}
            </p>
            
            <h3 class="text-xl font-semibold text-[#001F3F] mb-3">
              {await t(locale, 'privacy.data.rights.title')}
            </h3>
            <p class="text-gray-700 mb-4">
              {await t(locale, 'privacy.data.rights.description')}
            </p>
          </section>
          
          <section>
            <h2 class="text-2xl font-semibold text-[#001F3F] mb-4">
              {await t(locale, 'privacy.contact.title')}
            </h2>
            <div class="bg-gray-50 p-6 rounded-lg">
              <div class="grid md:grid-cols-2 gap-6">
                <div>
                  <h3 class="text-lg font-semibold mb-2">
                    {await t(locale, 'privacy.contact.email')}
                  </h3>
                  <p class="text-gray-700 mb-4">
                    <a href="mailto:info@youngdolphins.nl" class="text-[#001F3F] hover:underline">
                      info@youngdolphins.nl
                    </a>
                  </p>
                </div>
                
                <div>
                  <h3 class="text-lg font-semibold mb-2">
                    {await t(locale, 'privacy.contact.phone')}
                  </h3>
                  <p class="text-gray-700 mb-4">
                    <a href="https://wa.me/31628421354" class="text-[#001F3F] hover:underline">
                      06-28421354
                    </a>
                  </p>
                </div>
                
                <div>
                  <h3 class="text-lg font-semibold mb-2">
                    {await t(locale, 'privacy.contact.address')}
                  </h3>
                  <p class="text-gray-700 mb-4">
                    {await t(locale, 'privacy.contact.address.text')}
                  </p>
                </div>
              </div>
            </div>
          </section>
        </div>
      </div>
    </Container>
  </Layout>
</Container>
