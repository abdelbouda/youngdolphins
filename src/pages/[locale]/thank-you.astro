---
export async function getStaticPaths() {
  return [
    { params: { locale: 'nl' } },
    { params: { locale: 'en' } },
  ];
}

const { locale } = Astro.params;
import Layout from '../../layouts/Layout.astro';
import ThankYou from '../thank-you.astro';
---

<Layout locale={locale}>
  <ThankYou locale={locale} />
</Layout>
