---
import Container from '../ui/Container.astro';
import { t, tObject } from '../../i18n/ui';
import type { Locale } from '../../i18n/types';

interface Props {
  locale?: Locale;
}

const { locale = 'nl' } = Astro.props;

const title = await t(locale, 'features.title');
const items = await tObject(locale, 'features.items') as Array<{title: string, description: string}>;

const featureIcons = [
  // Kinderen (nu 1e item) - ster/diploma icoon
  `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>`,
  // Privé (nu 2e item) - persoon met aandacht icoon
  `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>`,
];
---

<section id="features" class="py-16 sm:py-24 bg-white" aria-labelledby="features-title">
  <Container>

    <div class="text-center mb-10 sm:mb-14 px-4">
      <h2 id="features-title" class="text-2xl sm:text-3xl md:text-4xl font-bold text-[#001F3F] leading-tight">
        {title}
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 sm:gap-8 px-4 max-w-4xl mx-auto">

      {items && items.map((item, i) => (
        <div class="bg-[#F7FBFF] border border-[#E1EEF7] rounded-2xl p-6 sm:p-8 shadow-sm hover:shadow-md transition-shadow">

          <div class="w-14 h-14 flex items-center justify-center rounded-full bg-[#00AEEF]/10 text-[#00AEEF] mb-5">
            <Fragment set:html={featureIcons[i] ?? featureIcons[0]} />
          </div>

          <h3 class="text-lg sm:text-xl font-semibold text-[#001F3F] mb-3">
            {item.title}
          </h3>

          <p class="text-gray-600 leading-relaxed text-sm sm:text-base">
            {item.description}
          </p>

        </div>
      ))}

    </div>

  </Container>
</section>
