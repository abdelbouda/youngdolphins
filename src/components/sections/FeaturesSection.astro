---
import Container from '../ui/Container.astro';
import { t, tObject } from '../../i18n/ui';
import type { Locale } from '../../i18n/types';

interface Props {
  locale?: Locale;
}

const { locale = 'nl' } = Astro.props;

// i18n
const title = await t(locale, 'features.title');
const items = await tObject(locale, 'features.items');
---

<section id="features" class="py-24 bg-white">
  <Container>

    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-[#001F3F] mb-4">
        {title}
      </h2>
    </div>

    <!-- Feature Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">

      {items.map((item) => (
        <div class="bg-[#F7FBFF] border border-[#E1EEF7] rounded-2xl p-8 shadow-sm hover:shadow-md transition-shadow">

          <!-- Icon bubble -->
          <div class="w-14 h-14 flex items-center justify-center rounded-full bg-[#00AEEF]/10 text-[#00AEEF] text-3xl mb-6">
            🐬
          </div>

          <h3 class="text-xl font-semibold text-[#001F3F] mb-3">
            {item.title}
          </h3>

          <p class="text-gray-600 leading-relaxed">
            {item.description}
          </p>

        </div>
      ))}

    </div>

  </Container>
</section>
