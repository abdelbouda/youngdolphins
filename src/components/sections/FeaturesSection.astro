---
import Container from '../ui/Container.astro';
import { t, tArray, tObject } from '../../i18n/ui';
import type { Locale } from '../../i18n/types';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;

// Translations
const title = await t(locale, 'features.title');
const items = await tObject(locale, 'features.items');
---

<section id="features" class="py-16 bg-primary">
  <Container>

    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">
        {title}
      </h2>
      <p class="text-xl text-white/70 max-w-2xl mx-auto">
        <!-- Optional subtitle if needed -->
      </p>
    </div>

    <!-- Features List -->
    <div class="space-y-24">

      <!-- Feature 1 -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <h3 class="text-3xl font-semibold text-white mb-4">
            {items[0].title}
          </h3>

          <p class="text-lg text-white/70 mb-8">
            {items[0].description}
          </p>

          <div class="space-y-3 text-white/80">
            <div class="flex items-center">
              <div class="w-1 h-1 bg-secondary rounded-full mr-3"></div>
              <span>Warm water introduction</span>
            </div>
            <div class="flex items-center">
              <div class="w-1 h-1 bg-secondary rounded-full mr-3"></div>
              <span>Parent‑child bonding</span>
            </div>
            <div class="flex items-center">
              <div class="w-1 h-1 bg-secondary rounded-full mr-3"></div>
              <span>Play‑based learning</span>
            </div>
          </div>
        </div>

        <div>
          <div class="relative overflow-hidden rounded-lg border border-white/10 bg-primary/40 h-64 flex items-center justify-center">
            <span class="text-white/40 text-sm">Swimming visual placeholder</span>
          </div>
        </div>
      </div>

      <!-- Feature 2 -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div class="order-2 lg:order-1">
          <div class="relative overflow-hidden rounded-lg border border-white/10 bg-primary/40 h-64 flex items-center justify-center">
            <span class="text-white/40 text-sm">Swimming visual placeholder</span>
          </div>
        </div>

        <div class="order-1 lg:order-2">
          <h3 class="text-3xl font-semibold text-white mb-4">
            {items[1].title}
          </h3>

          <p class="text-lg text-white/70 mb-8">
            {items[1].description}
          </p>

          <div class="space-y-3 text-white/80">
            <div class="flex items-center">
              <div class="w-1 h-1 bg-secondary rounded-full mr-3"></div>
              <span>Step‑by‑step learning</span>
            </div>
            <div class="flex items-center">
              <div class="w-1 h-1 bg-secondary rounded-full mr-3"></div>
              <span>Certified instructors</span>
            </div>
            <div class="flex items-center">
              <div class="w-1 h-1 bg-secondary rounded-full mr-3"></div>
              <span>Safe & warm pools</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Feature 3 -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <h3 class="text-3xl font-semibold text-white mb-4">
            {items[2].title}
          </h3>

          <p class="text-lg text-white/70 mb-8">
            {items[2].description}
          </p>

          <div class="space-y-3 text-white/80">
            <div class="flex items-center">
              <div class="w-1 h-1 bg-secondary rounded-full mr-3"></div>
              <span>1‑on‑1 guidance</span>
            </div>
            <div class="flex items-center">
              <div class="w-1 h-1 bg-secondary rounded-full mr-3"></div>
              <span>Faster progress</span>
            </div>
            <div class="flex items-center">
              <div class="w-1 h-1 bg-secondary rounded-full mr-3"></div>
              <span>Personalized lesson plan</span>
            </div>
          </div>
        </div>

        <div>
          <div class="relative overflow-hidden rounded-lg border border-white/10 bg-primary/40 h-64 flex items-center justify-center">
            <span class="text-white/40 text-sm">Swimming visual placeholder</span>
          </div>
        </div>
      </div>

    </div>

  </Container>
</section>
