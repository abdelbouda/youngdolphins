---
import Container from '../ui/Container.astro';
import logo from '../../assets/logo.webp';
---

<footer class="py-12 bg-[#001F3F] border-t border-blue-900 text-white">
  <Container>
    <div class="text-center">

      <!-- Logo -->
      <div class="mb-8 flex justify-center">
        <img 
          src={logo.src} 
          alt="Young Dolphins logo" 
          class="h-14 w-auto opacity-95"
        />
      </div>

      <!-- Links -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6 sm:gap-10 mb-8 text-sm">
        <a href="/" class="text-blue-200 hover:text-white transition-colors">
          Home
        </a>
        <a href="/#features" class="text-blue-200 hover:text-white transition-colors">
          Onze lessen
        </a>
        <a href="/#faq" class="text-blue-200 hover:text-white transition-colors">
          Veelgestelde vragen
        </a>
        <a href="/terms" class="text-blue-200 hover:text-white transition-colors">
          Algemene voorwaarden
        </a>
        <a href="/privacy" class="text-blue-200 hover:text-white transition-colors">
          Privacybeleid
        </a>
        <a href="mailto:info@youngdolphins.nl" class="text-blue-200 hover:text-white transition-colors">
          Contact
        </a>
      </div>

      <!-- Copyright -->
      <p class="text-blue-300 text-xs">
        © 2025 Young Dolphins. Alle rechten voorbehouden.
      </p>

    </div>
  </Container>
</footer>
