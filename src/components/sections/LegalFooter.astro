---
import Container from '../ui/Container.astro';
import logo from '../../assets/logo.webp';
---

<footer class="py-14 bg-[#001F3F] border-t border-blue-900 text-white">
  <Container>
    <div class="text-center px-4">

      <!-- Logo -->
      <div class="mb-8 flex justify-center">
        <img 
          src={logo.src} 
          alt="Young Dolphins logo" 
          class="h-20 sm:h-24 w-auto opacity-95"
        />
      </div>

      <!-- Contact Info -->
      <div class="flex flex-col sm:flex-row justify-center items-center gap-6 mb-10 text-sm">

        <!-- WhatsApp -->
        <a 
          href="https://wa.me/31628421354" 
          class="flex items-center text-[#00C2CB] hover:text-[#00A7AF] transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" 
               viewBox="0 0 24 24" class="w-5 h-5 mr-2">
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.12.55 4.11 1.51 5.86L0 24l6.29-1.64A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22a9.94 9.94 0 01-5.09-1.39l-.36-.21-3.73.97.99-3.63-.24-.37A9.94 9.94 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10zm5.07-7.93c-.27-.14-1.59-.78-1.84-.87-.25-.09-.43-.14-.61.14-.18.27-.7.87-.86 1.05-.16.18-.32.2-.59.07-.27-.14-1.14-.42-2.17-1.34-.8-.71-1.34-1.58-1.5-1.85-.16-.27-.02-.42.12-.56.12-.12.27-.32.41-.48.14-.16.18-.27.27-.45.09-.18.05-.34-.02-.48-.07-.14-.61-1.47-.84-2.02-.22-.53-.45-.46-.61-.47h-.52c-.18 0-.48.07-.73.34-.25.27-.96.94-.96 2.29s.98 2.65 1.12 2.83c.14.18 1.93 2.95 4.68 4.14.65.28 1.16.45 1.56.58.65.21 1.24.18 1.71.11.52-.08 1.59-.65 1.82-1.28.23-.63.23-1.17.16-1.28-.07-.11-.25-.18-.52-.32z"/>
          </svg>
          06‑28421354
        </a>

        <!-- Email -->
        <a 
          href="mailto:info@youngdolphins.nl" 
          class="flex items-center text-blue-200 hover:text-white transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" 
               viewBox="0 0 24 24" class="w-5 h-5 mr-2">
            <path d="M12 13.065L.015 6h23.97L12 13.065zM0 8.235V18h24V8.235l-12 7.065L0 8.235z"/>
          </svg>
          info@youngdolphins.nl
        </a>

      </div>

      <!-- Navigation Links -->
      <nav 
        aria-label="Footer navigation"
        class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-10 mb-10 text-sm"
      >
        <a href="/" class="text-blue-200 hover:text-white transition-colors">Home</a>
        <a href="/#features" class="text-blue-200 hover:text-white transition-colors">Onze lessen</a>
        <a href="/#faq" class="text-blue-200 hover:text-white transition-colors">Veelgestelde vragen</a>
        <a href="/terms" class="text-blue-200 hover:text-white transition-colors">Algemene voorwaarden</a>
        <a href="/privacy" class="text-blue-200 hover:text-white transition-colors">Privacybeleid</a>
      </nav>

      <!-- Copyright -->
      <p class="text-blue-300 text-xs">
        © {new Date().getFullYear()} Young Dolphins. Alle rechten voorbehouden.
      </p>

    </div>
  </Container>
</footer>
