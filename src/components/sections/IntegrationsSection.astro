---
import Container from '../ui/Container.astro';
import { t } from '../../i18n/ui';
import type { Locale } from '../../i18n/types';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;

const title = await t(locale, 'integrations.title');
const subtitle = await t(locale, 'integrations.subtitle');
---

<section id="locations" class="py-16 bg-primary">
  <Container>

    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">
        {title}
      </h2>

      <p class="text-xl text-white/70 max-w-2xl mx-auto">
        {subtitle}
      </p>
    </div>

    <!-- Locations Grid -->
    <div class="space-y-16">

      <!-- Location Group 1 -->
      <div>
        <h3 class="text-2xl font-semibold text-white text-center mb-8">
          Amsterdam West
        </h3>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6 text-center max-w-4xl mx-auto">
          <div class="text-white/70 text-sm">De Mirandabad</div>
          <div class="text-white/70 text-sm">Sportfondsenbad</div>
          <div class="text-white/70 text-sm">Sloterparkbad</div>
          <div class="text-white/70 text-sm">Noorderparkbad</div>
          <div class="text-white/70 text-sm">Het Marnix</div>
          <div class="text-white/70 text-sm">Flevoparkbad</div>
        </div>
      </div>

      <!-- Location Group 2 -->
      <div>
        <h3 class="text-2xl font-semibold text-white text-center mb-8">
          Amsterdam Oost
        </h3>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center max-w-2xl mx-auto">
          <div class="text-white/70 text-sm">Zeeburgbad</div>
          <div class="text-white/70 text-sm">Oosterparkbad</div>
          <div class="text-white/70 text-sm">Wibautbad</div>
          <div class="text-white/70 text-sm">Watergraafsmeerbad</div>
        </div>
      </div>

      <!-- Location Group 3 -->
      <div>
        <h3 class="text-2xl font-semibold text-white text-center mb-8">
          Special Programs
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 text-center max-w-xl mx-auto">
          <div class="text-white/70 text-sm">Baby & Peuter lessen</div>
          <div class="text-white/70 text-sm">Privélessen</div>
          <div class="text-white/70 text-sm">Versneld A/B/C traject</div>
        </div>
      </div>

    </div>

    <!-- Facilities -->
    <div class="mt-16 max-w-3xl mx-auto">
      <div class="space-y-6">

        <div class="text-center border-b border-white/10 pb-6">
          <h4 class="text-lg font-semibold text-white mb-2">Warm Water Pools</h4>
          <p class="text-white/70 text-sm">
            All our pools are heated and child‑friendly, ensuring a comfortable learning environment.
          </p>
        </div>

        <div class="text-center border-b border-white/10 pb-6">
          <h4 class="text-lg font-semibold text-white mb-2">Certified Instructors</h4>
          <p class="text-white/70 text-sm">
            Our team is fully certified and trained to teach children of all ages and skill levels.
          </p>
        </div>

        <div class="text-center pb-6">
          <h4 class="text-lg font-semibold text-white mb-2">Safe & Modern Facilities</h4>
          <p class="text-white/70 text-sm">
            We work only with pools that meet the highest safety and hygiene standards.
          </p>
        </div>

      </div>
    </div>

    <!-- Call to Action -->
    <div class="text-center mt-16">
      <h3 class="text-3xl font-semibold text-white mb-4">
        Ready to start swimming?
      </h3>
      <p class="text-lg text-white/70 mb-8">
        Choose the location that fits your schedule and enroll today.
      </p>
      <a href="#hero" class="inline-flex items-center px-8 py-3 bg-secondary text-primary hover:bg-secondary/90 transition-colors font-semibold rounded">
        Enroll now
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>

  </Container>
</section>
