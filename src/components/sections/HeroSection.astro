---
import Container from '../ui/Container.astro';
import { t } from '../../i18n/utils';
import type { Locale } from '../../i18n/types';

interface Props {
  locale?: Locale;
}

const { locale = 'nl' } = Astro.props;

const title = await t(locale, 'hero.title');
const subtitle = await t(locale, 'hero.subtitle');
const statDiplomas = await t(locale, 'hero.stats.diplomas');
const statSuccess = await t(locale, 'hero.stats.success');
const statRating = await t(locale, 'hero.stats.rating');
const continueReading = await t(locale, 'hero.continue_reading');

// Nieuwe labels voor de knoppen
const labels = {
  directRegister: locale === 'en' ? 'Register Now' : 'Direct Aanmelden',
  directContact: locale === 'en' ? 'Direct Contact' : 'Direct Contact'
};

const registerHref = `/${locale}/aanmelden`;
---

<section
  id="hero"
  class="relative pt-24 pb-16 sm:pt-32 sm:pb-20 bg-gradient-to-b from-[#E6F4FF] to-white overflow-hidden"
>
  <div class="absolute inset-0 opacity-30 pointer-events-none" aria-hidden="true">
    <div class="absolute top-10 left-10 w-32 h-32 sm:w-40 sm:h-40 bg-[#00AEEF]/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-10 w-44 h-44 sm:w-56 sm:h-56 bg-[#001F3F]/20 rounded-full blur-3xl"></div>
  </div>

  <Container class="relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">

      <div class="text-center lg:text-left space-y-5 sm:space-y-6 hero-fade px-2 sm:px-4">

        <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold leading-tight text-[#001F3F]">
          {title}
        </h1>

        <p class="text-base sm:text-lg text-gray-700 max-w-xl mx-auto lg:mx-0 leading-relaxed">
          {subtitle}
        </p>

        <div class="flex flex-col sm:flex-row gap-3 pt-2 justify-center lg:justify-start">
          <a
            href={registerHref}
            class="cta-register w-full sm:w-auto text-center"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/>
            </svg>
            {labels.directRegister}
          </a>
          <a
            href="https://wa.me/31628421354"
            target="_blank"
            class="cta-whatsapp w-full sm:w-auto text-center"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mr-2" viewBox="0 0 48 48" fill="currentColor">
              <path d="M24 4C13 4 4 13 4 24c0 3.6 1 7 2.7 9.9L4 44l10.4-2.7C17.2 43 20.5 44 24 44c11 0 20-9 20-20S35 4 24 4zm0 36c-3.1 0-6.1-.8-8.7-2.4l-.6-.4-6.2 1.6 1.6-6-.4-.6C8.8 30.1 8 27.1 8 24 8 15.2 15.2 8 24 8s16 7.2 16 16-7.2 16-16 16zm8.8-11.8c-.5-.2-2.8-1.4-3.2-1.5-.4-.2-.7-.2-1 .2-.3.4-1.1 1.5-1.4 1.8-.3.3-.5.4-1 .1-.5-.2-2-.7-3.8-2.3-1.4-1.2-2.3-2.8-2.6-3.2-.3-.5 0-.7.2-1 .2-.2.5-.5.7-.8.2-.3.3-.5.4-.8.1-.3 0-.6-.1-.8-.1-.2-1-2.5-1.4-3.4-.4-.9-.7-.8-1-.8h-.9c-.3 0-.8.1-1.2.6-.4.5-1.6 1.6-1.6 3.8 0 2.2 1.6 4.4 1.9 4.7.3.3 3.2 4.8 7.7 6.7 1.1.5 1.9.7 2.6.9 1.1.3 2.1.3 2.9.2.9-.1 2.8-1.1 3.2-2.2.4-1.1.4-2 .3-2.2-.2-.3-.5-.4-1-.6z"/>
            </svg>
            {labels.directContact}
          </a>
        </div>

        <div class="grid grid-cols-3 gap-3 sm:gap-6 pt-4 max-w-xs sm:max-w-md mx-auto lg:mx-0">
          <div class="text-center lg:text-left">
            <div class="text-2xl sm:text-3xl font-bold text-[#001F3F]">1200+</div>
            <div class="text-[10px] sm:text-xs text-gray-600 leading-tight mt-0.5">{statDiplomas}</div>
          </div>
          <div class="text-center lg:text-left">
            <div class="text-2xl sm:text-3xl font-bold text-[#001F3F]">98%</div>
            <div class="text-[10px] sm:text-xs text-gray-600 leading-tight mt-0.5">{statSuccess}</div>
          </div>
          <div class="text-center lg:text-left">
            <div class="text-2xl sm:text-3xl font-bold text-[#001F3F]">4.9★</div>
            <div class="text-[10px] sm:text-xs text-gray-600 leading-tight mt-0.5">{statRating}</div>
          </div>
        </div>
      </div>

      <div class="flex justify-center items-center hero-fade px-4 sm:px-8 lg:px-4">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 w-full max-w-5xl">
          <!-- Starter Card -->
          <div class="pricing-card-3d bg-white rounded-xl p-4 shadow-lg border border-gray-100 transform hover:scale-105 transition-all duration-300">
            <div class="text-center">
              <h3 class="text-lg font-bold text-[#001F3F] mb-1">Starter</h3>
              <div class="text-2xl font-bold text-[#00AEEF] mb-1">€25</div>
              <div class="text-xs text-gray-600 mb-2">/ les</div>
              <p class="text-xs text-gray-700 mb-2">Perfect voor kennismaking.</p>
              <ul class="text-left text-xs text-gray-600 space-y-1 mb-3">
                <li class="flex items-center"><span class="text-green-500 mr-1">✓</span>1 les per week</li>
                <li class="flex items-center"><span class="text-green-500 mr-1">✓</span>Kleine groepen</li>
                <li class="flex items-center"><span class="text-green-500 mr-1">✓</span>Warm zwembad</li>
                <li class="flex items-center"><span class="text-green-500 mr-1">✓</span>Gecertificeerde instructeurs</li>
              </ul>
              <a href={`${registerHref}?pakket=starter`} class="cta-register w-full text-center block py-2 text-sm">Inschrijven</a>
            </div>
          </div>

          <!-- Progress+ Card -->
          <div class="pricing-card-3d bg-gradient-to-br from-[#00AEEF] to-[#0096ce] rounded-xl p-4 shadow-xl border-2 border-[#00AEEF] transform hover:scale-105 transition-all duration-300 relative">
            <div class="absolute -top-2 left-1/2 -translate-x-1/2 bg-[#001F3F] text-white text-xs font-bold px-2 py-0.5 rounded-full">
              MEEST GEKOZEN
            </div>
            <div class="text-center">
              <h3 class="text-lg font-bold text-white mb-1">Progress+</h3>
              <div class="text-2xl font-bold text-white mb-1">€170</div>
              <div class="text-xs text-white/90 mb-2">/ maand</div>
              <p class="text-xs text-white/90 mb-2">Sneller leren met extra begeleiding.</p>
              <ul class="text-left text-xs text-white space-y-1 mb-3">
                <li class="flex items-center"><span class="mr-1">✓</span>2 lessen per week</li>
                <li class="flex items-center"><span class="mr-1">✓</span>Voortgangsrapportage</li>
                <li class="flex items-center"><span class="mr-1">✓</span>Extra persoonlijke aandacht</li>
                <li class="flex items-center"><span class="mr-1">✓</span>Toegang tot alle locaties</li>
                <li class="flex items-center"><span class="mr-1">✓</span>Diploma A/B/C begeleiding</li>
              </ul>
              <a href={`${registerHref}?pakket=progress`} class="bg-white text-[#00AEEF] font-bold w-full text-center block py-2 rounded-lg hover:bg-gray-100 transition-colors text-sm">Inschrijven</a>
            </div>
          </div>

          <!-- Privé Card -->
          <div class="pricing-card-3d bg-white rounded-xl p-4 shadow-lg border border-gray-100 transform hover:scale-105 transition-all duration-300">
            <div class="text-center">
              <h3 class="text-lg font-bold text-[#001F3F] mb-1">Privé</h3>
              <div class="text-2xl font-bold text-[#00AEEF] mb-1">€50</div>
              <div class="text-xs text-gray-600 mb-2">/ les</div>
              <p class="text-xs text-gray-700 mb-2">1‑op‑1 begeleiding voor maximale progressie.</p>
              <ul class="text-left text-xs text-gray-600 space-y-1 mb-3">
                <li class="flex items-center"><span class="text-green-500 mr-1">✓</span>Privéles</li>
                <li class="flex items-center"><span class="text-green-500 mr-1">✓</span>Snellere vooruitgang</li>
                <li class="flex items-center"><span class="text-green-500 mr-1">✓</span>Persoonlijk lesplan</li>
                <li class="flex items-center"><span class="text-green-500 mr-1">✓</span>Flexibele tijden</li>
                <li class="flex items-center"><span class="text-green-500 mr-1">✓</span>Diploma A/B/C versneld traject</li>
              </ul>
              <a href={`${registerHref}?pakket=private`} class="cta-register w-full text-center block py-2 text-sm">Inschrijven</a>
            </div>
          </div>
        </div>
      </div>

    </div>
  </Container>

  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-10 hero-fade hidden sm:flex">
    <a href="#features" class="group flex flex-col items-center gap-1" aria-label={continueReading}>
      <span class="text-xs text-gray-500 font-medium">{continueReading}</span>
      <svg class="w-4 h-4 text-gray-400 group-hover:text-[#00AEEF] transition animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
      </svg>
    </a>
  </div>
</section>

<style is:global>
  .hero-fade {
    opacity: 0;
    transform: translateY(12px);
    animation: fadeUp 0.7s ease forwards;
  }

  @keyframes fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .cta-register {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: #00AEEF; /* Match met header 'Aanmelden' */
    color: #ffffff !important;
    font-weight: 700;
    padding: 0.875rem 1.75rem;
    border-radius: 0.75rem;
    transition: all 0.2s ease;
    box-shadow: 0 4px 12px rgba(0, 174, 239, 0.25);
    font-size: 1rem;
    min-height: 54px;
    text-decoration: none !important;
  }

  .cta-register:hover {
    background-color: #0096ce;
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(0, 174, 239, 0.35);
  }

  .cta-whatsapp {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: #25D366; /* WhatsApp Groen */
    color: #ffffff !important;
    font-weight: 700;
    padding: 0.875rem 1.75rem;
    border-radius: 0.75rem;
    transition: all 0.2s ease;
    box-shadow: 0 4px 12px rgba(37, 211, 102, 0.25);
    font-size: 1rem;
    min-height: 54px;
    text-decoration: none !important;
  }

  .cta-whatsapp:hover {
    background-color: #1ebe57;
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(37, 211, 102, 0.35);
  }

  .pricing-card-3d {
    position: relative;
    transform-style: preserve-3d;
    perspective: 1000px;
  }

  .pricing-card-3d::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 100%);
    border-radius: 1rem;
    pointer-events: none;
  }

  .pricing-card-3d::after {
    content: '';
    position: absolute;
    bottom: -8px;
    left: 8px;
    right: -8px;
    top: 8px;
    background: rgba(0, 31, 63, 0.1);
    border-radius: 1rem;
    z-index: -1;
    transform: translateZ(-10px);
    transition: all 0.3s ease;
  }

  .pricing-card-3d:hover::after {
    bottom: -12px;
    left: 12px;
    right: -12px;
    top: 12px;
    background: rgba(0, 31, 63, 0.15);
  }

  .pricing-card-3d:hover {
    transform: translateY(-8px) scale(1.02);
    box-shadow: 0 20px 40px rgba(0, 174, 239, 0.2);
  }
</style>
