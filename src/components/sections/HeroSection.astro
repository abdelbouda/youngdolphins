---
import Container from '../ui/Container.astro';
import { t } from '../../i18n/ui';
import type { Locale } from '../../i18n/types';
import heroImg from '../../assets/hero-kids.webp';

interface Props {
  locale?: Locale;
}

const { locale = 'nl' } = Astro.props;

// i18n
const title = await t(locale, 'hero.title');
const subtitle = await t(locale, 'hero.subtitle');
const ctaPrimary = await t(locale, 'hero.cta_primary');
const ctaSecondary = await t(locale, 'hero.cta_secondary');
const statDiplomas = await t(locale, 'hero.stats.diplomas');
const statSuccess = await t(locale, 'hero.stats.success');
const statRating = await t(locale, 'hero.stats.rating');
const continueReading = await t(locale, 'hero.continue_reading');
---

<section id="hero" class="relative min-h-[85vh] md:min-h-screen bg-gradient-to-b from-[#E6F4FF] to-white overflow-hidden">

  <!-- Decorative bubbles -->
  <div class="absolute inset-0 opacity-30 pointer-events-none">
    <div class="absolute top-10 left-10 w-40 h-40 bg-[#00AEEF]/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-10 w-56 h-56 bg-[#001F3F]/20 rounded-full blur-3xl"></div>
  </div>

  <Container class="relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center pt-28 pb-20">

      <!-- LEFT COLUMN -->
      <div class="text-center lg:text-left space-y-6">

        <!-- Title -->
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-bold leading-tight text-[#001F3F]">
          {title}
        </h1>

        <!-- Subtitle -->
        <p class="text-lg sm:text-xl text-gray-700 max-w-xl mx-auto lg:mx-0 leading-relaxed">
          {subtitle}
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 pt-4">
          <a 
            href="/#pricing"
            class="px-6 py-3 bg-[#001F3F] text-white rounded-lg font-semibold shadow hover:bg-[#00306A] transition-colors text-center"
          >
            {ctaPrimary}
          </a>

          <a 
            href="/#faq"
            class="px-6 py-3 bg-white border border-[#001F3F] text-[#001F3F] rounded-lg font-semibold hover:bg-[#F0F7FF] transition-colors text-center"
          >
            {ctaSecondary}
          </a>
        </div>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-6 pt-6 max-w-md mx-auto lg:mx-0">
          <div class="text-center lg:text-left">
            <div class="text-3xl font-bold text-[#001F3F]">1200+</div>
            <div class="text-xs text-gray-600">{statDiplomas}</div>
          </div>
          <div class="text-center lg:text-left">
            <div class="text-3xl font-bold text-[#001F3F]">98%</div>
            <div class="text-xs text-gray-600">{statSuccess}</div>
          </div>
          <div class="text-center lg:text-left">
            <div class="text-3xl font-bold text-[#001F3F]">4.9★</div>
            <div class="text-xs text-gray-600">{statRating}</div>
          </div>
        </div>

      </div>

      <!-- RIGHT COLUMN -->
      <div class="flex justify-center items-center">
        <img 
          src={heroImg.src} 
          alt="Kinderen leren zwemmen bij Young Dolphins"
          class="w-full max-w-md h-auto rounded-xl shadow-xl"
          loading="eager"
        />
      </div>

    </div>
  </Container>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 z-10">
    <a href="#features" class="group flex flex-col items-center gap-2">
      <span class="text-sm text-gray-600 font-medium">{continueReading}</span>
      <svg class="w-5 h-5 text-gray-500 group-hover:text-[#00AEEF] transition" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
      </svg>
    </a>
  </div>

</section>
