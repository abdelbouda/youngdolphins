---
import Container from '../ui/Container.astro';
import { t } from '../../i18n/utils';
import type { Locale } from '../../i18n/types';

interface Props {
  locale?: Locale;
}

const { locale = 'nl' } = Astro.props;

const finalTitle = await t(locale, 'final.title');
const finalSubtitle = await t(locale, 'final.subtitle');
const finalCTA = await t(locale, 'final.cta');
---

<section id="final" class="py-24 bg-[#F7FBFF]">
  <Container>
    <div class="text-center max-w-2xl mx-auto">

      <h2 class="text-3xl sm:text-4xl font-bold text-[#001F3F] mb-4">
        {finalTitle}
      </h2>

      <p class="text-lg text-gray-700 mb-10">
        {finalSubtitle}
      </p>

      <a 
        href="/contact"
        class="inline-flex items-center px-8 py-4 bg-[#001F3F] text-white rounded-lg font-semibold hover:bg-[#00306A] transition-colors"
      >
        {finalCTA}
        <svg class="ml-2 w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>

    </div>
  </Container>
</section>
