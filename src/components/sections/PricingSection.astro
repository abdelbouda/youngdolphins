---
import Container from '../ui/Container.astro';
import { t } from '../../i18n/ui';
import type { Locale } from '../../i18n/types';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;

// Translations
const title = await t(locale, 'pricing.title');
const subtitle = await t(locale, 'pricing.subtitle');
const cta = await t(locale, 'pricing.cta');
---

<section id="pricing" class="py-16 bg-primary">
  <Container>

    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">
        {title}
      </h2>

      <p class="text-xl text-white/70 max-w-2xl mx-auto">
        {subtitle}
      </p>
    </div>

    <!-- Pricing Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto mb-16">

      <!-- Package 1 -->
      <div class="text-center bg-primary/60 border border-white/10 rounded-xl p-8">
        <h3 class="text-xl font-semibold text-white mb-2">Starter</h3>
        <div class="flex items-baseline justify-center mb-4">
          <span class="text-4xl font-bold text-white">€15</span>
          <span class="text-lg text-white/60 ml-1">/ les</span>
        </div>
        <p class="text-white/70 text-sm mb-6">Perfect for kennismaking en eerste zwemlessen.</p>

        <ul class="space-y-2 mb-8 text-sm text-white/70">
          <li>1 les per week</li>
          <li>Kleine groepen</li>
          <li>Warm zwembad</li>
          <li>Gecertificeerde instructeurs</li>
        </ul>

        <a href="#hero" class="inline-flex items-center px-6 py-3 border border-white/20 text-white hover:bg-primary/40 transition-colors font-medium rounded text-sm">
          {cta}
        </a>
      </div>

      <!-- Package 2 (Most Popular) -->
      <div class="text-center bg-primary/80 border border-secondary/40 rounded-xl p-8 relative shadow-xl">
        <div class="absolute -top-3 left-1/2 transform -translate-x-1/2">
          <span class="px-3 py-1 text-xs text-primary bg-secondary rounded-full font-semibold">
            Most Popular
          </span>
        </div>

        <h3 class="text-xl font-semibold text-white mb-2">Progress+</h3>
        <div class="flex items-baseline justify-center mb-4">
          <span class="text-4xl font-bold text-white">€55</span>
          <span class="text-lg text-white/60 ml-1">/ maand</span>
        </div>
        <p class="text-white/70 text-sm mb-6">Sneller leren met extra begeleiding.</p>

        <ul class="space-y-2 mb-8 text-sm text-white/70">
          <li>2 lessen per week</li>
          <li>Voortgangsrapportage</li>
          <li>Extra persoonlijke aandacht</li>
          <li>Toegang tot alle locaties</li>
          <li>Diploma A/B/C begeleiding</li>
        </ul>

        <a href="#hero" class="inline-flex items-center px-6 py-3 bg-secondary text-primary hover:bg-secondary/90 transition-colors font-semibold rounded text-sm">
          {cta}
        </a>
      </div>

      <!-- Package 3 -->
      <div class="text-center bg-primary/60 border border-white/10 rounded-xl p-8">
        <h3 class="text-xl font-semibold text-white mb-2">Privé</h3>
        <div class="flex items-baseline justify-center mb-4">
          <span class="text-4xl font-bold text-white">€35</span>
          <span class="text-lg text-white/60 ml-1">/ les</span>
        </div>
        <p class="text-white/70 text-sm mb-6">1‑op‑1 begeleiding voor maximale progressie.</p>

        <ul class="space-y-2 mb-8 text-sm text-white/70">
          <li>Privéles</li>
          <li>Snellere vooruitgang</li>
          <li>Persoonlijk lesplan</li>
          <li>Flexibele tijden</li>
          <li>Diploma A/B/C versneld traject</li>
        </ul>

        <a href="#hero" class="inline-flex items-center px-6 py-3 border border-white/20 text-white hover:bg-primary/40 transition-colors font-medium rounded text-sm">
          {cta}
        </a>
      </div>

    </div>

    <!-- Comparison Table -->
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-8">
        <h3 class="text-2xl font-semibold text-white mb-6">
          Compare plans
        </h3>
      </div>

      <div class="space-y-4 text-sm text-white/80">

        <div class="grid grid-cols-4 gap-4 py-3 border-b border-white/10">
          <div class="font-semibold">Features</div>
          <div class="text-center">Starter</div>
          <div class="text-center">Progress+</div>
          <div class="text-center">Privé</div>
        </div>

        <div class="grid grid-cols-4 gap-4 py-3 border-b border-white/10">
          <div>Lessons per week</div>
          <div class="text-center">1</div>
          <div class="text-center">2</div>
          <div class="text-center">1 (private)</div>
        </div>

        <div class="grid grid-cols-4 gap-4 py-3 border-b border-white/10">
          <div>Progress tracking</div>
          <div class="text-center">-</div>
          <div class="text-center">✓</div>
          <div class="text-center">✓</div>
        </div>

        <div class="grid grid-cols-4 gap-4 py-3 border-b border-white/10">
          <div>Personal guidance</div>
          <div class="text-center">-</div>
          <div class="text-center">✓</div>
          <div class="text-center">✓✓</div>
        </div>

        <div class="grid grid-cols-4 gap-4 py-3">
          <div>Access to all pools</div>
          <div class="text-center">-</div>
          <div class="text-center">✓</div>
          <div class="text-center">✓</div>
        </div>

      </div>
    </div>

  </Container>
</section>
