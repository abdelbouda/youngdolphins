---
import Container from '../ui/Container.astro';
import { t, tObject } from '../../i18n/ui';
import { getRelativeLocaleUrl } from 'astro:i18n';
import type { Locale } from '../../i18n/types';

interface Props {
  locale?: Locale;
}

const { locale = 'nl' } = Astro.props;

// Prijzen hardcoded conform jouw verzoek
const starterPrice = "25";
const progressPrice = "170";
const privatePrice = "50";

const title = await t(locale, 'pricing.title');
const subtitle = await t(locale, 'pricing.subtitle');
const cta = await t(locale, 'pricing.cta');

const starterFeatures = await tObject(locale, 'pricing.packages.starter.features') as string[];
const progressFeatures = await tObject(locale, 'pricing.packages.progress.features') as string[];
const privateFeatures = await tObject(locale, 'pricing.packages.private.features') as string[];

const registerUrl = getRelativeLocaleUrl(locale, 'register');

const headerLightBlue = "#00AEEF";
const headerDarkBlue = "#001F3F";
---

<section id="pricing" class="py-16 bg-[#F7FBFF] overflow-hidden">
  <Container>
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-[#001F3F] mb-4">{title}</h2>
      <p class="text-gray-600 max-w-2xl mx-auto">{subtitle}</p>
    </div>

    <div class="flex flex-col md:flex-row items-stretch justify-center gap-6 lg:gap-8 max-w-6xl mx-auto mb-10">
      
      <div class="flex-1 bg-white border border-[#E1EEF7] rounded-2xl p-8 flex flex-col shadow-sm">
        <h3 class="text-xl font-bold text-[#001F3F] mb-4 text-center uppercase tracking-tight">Starter</h3>
        <div class="flex items-baseline justify-center mb-6">
          <span class="text-xl font-bold text-[#001F3F]">€</span>
          <span class="text-5xl font-black text-[#001F3F]">{starterPrice}</span>
          <span class="text-gray-500 ml-1 text-sm">/ les</span>
        </div>
        <ul class="space-y-3 mb-10 flex-1">
          {starterFeatures.map(f => (
            <li class="flex items-start gap-2 text-sm text-gray-700">
              <svg class="w-5 h-5 text-[#00AEEF] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
              <span>{f}</span>
            </li>
          ))}
        </ul>
        <a href={registerUrl} class="btn-pricing"> {cta} </a>
      </div>

      <div class="flex-1 bg-white border-2 border-[#00AEEF] rounded-2xl p-8 flex flex-col shadow-xl relative md:scale-105 z-10">
        <div class="absolute -top-4 left-1/2 -translate-x-1/2 bg-[#00AEEF] text-white px-4 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest">
          Meest Gekozen
        </div>
        <h3 class="text-xl font-bold text-[#001F3F] mb-4 text-center uppercase tracking-tight">Progress+</h3>
        <div class="flex items-baseline justify-center mb-6">
          <span class="text-xl font-bold text-[#001F3F]">€</span>
          <span class="text-5xl font-black text-[#001F3F]">{progressPrice}</span>
          <span class="text-gray-500 ml-1 text-sm">/ maand</span>
        </div>
        <ul class="space-y-3 mb-10 flex-1">
          {progressFeatures.map(f => (
            <li class="flex items-start gap-2 text-sm text-gray-700">
              <svg class="w-5 h-5 text-[#00AEEF] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
              <span>{f}</span>
            </li>
          ))}
        </ul>
        <a href={registerUrl} class="btn-pricing"> {cta} </a>
      </div>

      <div class="flex-1 bg-white border border-[#E1EEF7] rounded-2xl p-8 flex flex-col shadow-sm">
        <h3 class="text-xl font-bold text-[#001F3F] mb-4 text-center uppercase tracking-tight">Privé</h3>
        <div class="flex items-baseline justify-center mb-6">
          <span class="text-xl font-bold text-[#001F3F]">€</span>
          <span class="text-5xl font-black text-[#001F3F]">{privatePrice}</span>
          <span class="text-gray-500 ml-1 text-sm">/ les</span>
        </div>
        <ul class="space-y-3 mb-10 flex-1">
          {privateFeatures.map(f => (
            <li class="flex items-start gap-2 text-sm text-gray-700">
              <svg class="w-5 h-5 text-[#00AEEF] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
              <span>{f}</span>
            </li>
          ))}
        </ul>
        <a href={registerUrl} class="btn-pricing"> {cta} </a>
      </div>

    </div>

    <div class="text-center mt-8 text-gray-400 text-[11px] italic space-y-1">
      <p>* {locale === 'nl' ? 'Inschrijfgeld bedraagt €25' : 'Registration fee is €25'}</p>
      <p>* {locale === 'nl' ? 'Kosten Afzwemmen incl. zwemdiploma €25' : 'Graduation costs incl. diploma €25'}</p>
    </div>
  </Container>
</section>

<style define:vars={{ headerLightBlue, headerDarkBlue }}>
  .btn-pricing {
    display: block;
    width: 100%;
    text-align: center;
    padding: 0.875rem;
    background-color: var(--headerLightBlue);
    color: white;
    font-weight: 900;
    border-radius: 0.75rem;
    transition: all 0.3s ease;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }
  .btn-pricing:hover {
    background-color: var(--headerDarkBlue);
    transform: translateY(-2px);
  }
</style>
