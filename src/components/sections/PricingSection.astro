---
import Container from '../ui/Container.astro';
import { t } from '../../i18n/ui';
import type { Locale } from '../../i18n/types';

interface Props {
  locale?: Locale;
}

const { locale = 'nl' } = Astro.props;

// Translations
const title = await t(locale, 'pricing.title');
const subtitle = await t(locale, 'pricing.subtitle');
const cta = await t(locale, 'pricing.cta');
---

<section id="pricing" class="py-24 bg-[#F7FBFF]">
  <Container>

    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-[#001F3F] mb-4">
        {title}
      </h2>

      <p class="text-gray-600 max-w-2xl mx-auto">
        {subtitle}
      </p>
    </div>

    <!-- Pricing Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 max-w-6xl mx-auto mb-20">

      <!-- Package 1 -->
      <div class="text-center bg-white border border-[#E1EEF7] rounded-2xl p-8 shadow-sm hover:shadow-md transition-all">
        <h3 class="text-xl font-semibold text-[#001F3F] mb-2">Starter</h3>

        <div class="flex items-baseline justify-center mb-4">
          <span class="text-4xl font-bold text-[#001F3F]">€15</span>
          <span class="text-lg text-gray-500 ml-1">/ les</span>
        </div>

        <p class="text-gray-600 text-sm mb-6">Perfect voor kennismaking en eerste zwemlessen.</p>

        <ul class="space-y-2 mb-8 text-sm text-gray-700">
          <li>1 les per week</li>
          <li>Kleine groepen</li>
          <li>Warm zwembad</li>
          <li>Gecertificeerde instructeurs</li>
        </ul>

        <a 
          href="#hero" 
          class="inline-block px-6 py-3 border border-[#001F3F] text-[#001F3F] hover:bg-[#E6F4FF] transition-colors font-medium rounded-lg text-sm"
        >
          {cta}
        </a>
      </div>

      <!-- Package 2 (Most Popular) -->
      <div class="text-center bg-white border-2 border-[#00AEEF] rounded-2xl p-8 shadow-lg scale-[1.03] relative">
        <div class="absolute -top-3 left-1/2 -translate-x-1/2">
          <span class="px-3 py-1 text-xs bg-[#00AEEF] text-white rounded-full font-semibold">
            Meest gekozen
          </span>
        </div>

        <h3 class="text-xl font-semibold text-[#001F3F] mb-2">Progress+</h3>

        <div class="flex items-baseline justify-center mb-4">
          <span class="text-4xl font-bold text-[#001F3F]">€55</span>
          <span class="text-lg text-gray-500 ml-1">/ maand</span>
        </div>

        <p class="text-gray-600 text-sm mb-6">Sneller leren met extra begeleiding.</p>

        <ul class="space-y-2 mb-8 text-sm text-gray-700">
          <li>2 lessen per week</li>
          <li>Voortgangsrapportage</li>
          <li>Extra persoonlijke aandacht</li>
          <li>Toegang tot alle locaties</li>
          <li>Diploma A/B/C begeleiding</li>
        </ul>

        <a 
          href="#hero" 
          class="inline-block px-6 py-3 bg-[#001F3F] text-white hover:bg-[#00306A] transition-colors font-semibold rounded-lg text-sm"
        >
          {cta}
        </a>
      </div>

      <!-- Package 3 -->
      <div class="text-center bg-white border border-[#E1EEF7] rounded-2xl p-8 shadow-sm hover:shadow-md transition-all">
        <h3 class="text-xl font-semibold text-[#001F3F] mb-2">Privé</h3>

        <div class="flex items-baseline justify-center mb-4">
          <span class="text-4xl font-bold text-[#001F3F]">€35</span>
          <span class="text-lg text-gray-500 ml-1">/ les</span>
        </div>

        <p class="text-gray-600 text-sm mb-6">1‑op‑1 begeleiding voor maximale progressie.</p>

        <ul class="space-y-2 mb-8 text-sm text-gray-700">
          <li>Privéles</li>
          <li>Snellere vooruitgang</li>
          <li>Persoonlijk lesplan</li>
          <li>Flexibele tijden</li>
          <li>Diploma A/B/C versneld traject</li>
        </ul>

        <a 
          href="#hero" 
          class="inline-block px-6 py-3 border border-[#001F3F] text-[#001F3F] hover:bg-[#E6F4FF] transition-colors font-medium rounded-lg text-sm"
        >
          {cta}
        </a>
      </div>

    </div>

    <!-- Comparison Table -->
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-8">
        <h3 class="text-2xl font-semibold text-[#001F3F] mb-6">
          Vergelijk pakketten
        </h3>
      </div>

      <div class="space-y-4 text-sm text-gray-700">

        <div class="grid grid-cols-4 gap-4 py-3 border-b border-gray-200 font-semibold">
          <div>Functie</div>
          <div class="text-center">Starter</div>
          <div class="text-center">Progress+</div>
          <div class="text-center">Privé</div>
        </div>

        <div class="grid grid-cols-4 gap-4 py-3 border-b border-gray-200">
          <div>Lessen per week</div>
          <div class="text-center">1</div>
          <div class="text-center">2</div>
          <div class="text-center">1 (privé)</div>
        </div>

        <div class="grid grid-cols-4 gap-4 py-3 border-b border-gray-200">
          <div>Voortgangsrapportage</div>
          <div class="text-center">-</div>
          <div class="text-center">✓</div>
          <div class="text-center">✓</div>
        </div>

        <div class="grid grid-cols-4 gap-4 py-3 border-b border-gray-200">
          <div>Persoonlijke begeleiding</div>
          <div class="text-center">-</div>
          <div class="text-center">✓</div>
          <div class="text-center">✓✓</div>
        </div>

        <div class="grid grid-cols-4 gap-4 py-3">
          <div>Toegang tot alle zwembaden</div>
          <div class="text-center">-</div>
          <div class="text-center">✓</div>
          <div class="text-center">✓</div>
        </div>

      </div>
    </div>

  </Container>
</section>
