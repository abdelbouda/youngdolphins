---
import Container from '../ui/Container.astro';
import { t, tObject } from '../../i18n/ui';
import { getRelativeLocaleUrl } from 'astro:i18n'; // Importeer voor juiste taal-links
import type { Locale } from '../../i18n/types';

interface Props {
  locale?: Locale;
}

const { locale = 'nl' } = Astro.props;

const title = await t(locale, 'pricing.title');
const subtitle = await t(locale, 'pricing.subtitle');
const cta = await t(locale, 'pricing.cta');

// Pakketten ophalen
const starter = {
  id: 'starter',
  name: await t(locale, 'pricing.packages.starter.name'),
  price: '€15',
  priceUnit: await t(locale, 'pricing.packages.starter.price_unit'),
  description: await t(locale, 'pricing.packages.starter.description'),
  features: await tObject(locale, 'pricing.packages.starter.features') as string[]
};

const progress = {
  id: 'progress',
  name: await t(locale, 'pricing.packages.progress.name'),
  badge: await t(locale, 'pricing.packages.progress.badge'),
  price: '€55',
  priceUnit: await t(locale, 'pricing.packages.progress.price_unit'),
  description: await t(locale, 'pricing.packages.progress.description'),
  features: await tObject(locale, 'pricing.packages.progress.features') as string[]
};

const priv = {
  id: 'private',
  name: await t(locale, 'pricing.packages.private.name'),
  price: '€35',
  priceUnit: await t(locale, 'pricing.packages.private.price_unit'),
  description: await t(locale, 'pricing.packages.private.description'),
  features: await tObject(locale, 'pricing.packages.private.features') as string[]
};

// Genereer de juiste URL naar de aanmeldpagina op basis van de taal
const registerUrl = getRelativeLocaleUrl(locale, 'register'); 

// De specifieke lichtblauwe kleur uit de Header (zie screenshot "Direct aanmelden")
const headerLightBlue = "#00AEEF";
const headerDarkBlue = "#001F3F";
---

<section id="pricing" class="py-16 sm:py-24 bg-[#F7FBFF]">
  <Container>

    <div class="text-center mb-10 sm:mb-14">
      <h2 class="text-2xl sm:text-4xl font-bold text-[#001F3F] mb-3">{title}</h2>
      <p class="text-gray-600 max-w-2xl mx-auto">{subtitle}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto mb-16">
      {[starter, progress, priv].map((pkg) => (
        <div class={`bg-white border ${pkg.id === 'progress' ? 'border-[#00AEEF] border-2 md:scale-[1.05] z-10 shadow-lg' : 'border-[#E1EEF7] shadow-sm'} rounded-2xl p-8 flex flex-col relative`}>
          
          {pkg.id === 'progress' && (
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="px-3 py-1 text-xs bg-[#00AEEF] text-white rounded-full font-bold uppercase">
                {progress.badge}
              </span>
            </div>
          )}

          <h3 class="text-xl font-bold text-[#001F3F] mb-2 text-center">{pkg.name}</h3>
          <div class="flex items-baseline justify-center mb-4">
            <span class="text-4xl font-bold text-[#001F3F]">{pkg.price}</span>
            <span class="text-gray-500 ml-1 text-sm">{pkg.priceUnit}</span>
          </div>

          <ul class="space-y-3 mb-8 flex-1">
            {pkg.features.map(f => (
              <li class="flex items-start gap-2 text-sm text-gray-700">
                <svg class="w-4 h-4 text-[#00AEEF] mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>
                {f}
              </li>
            ))}
          </ul>

          <a 
            href={registerUrl} 
            class="w-full text-center py-3 px-6 text-white font-bold rounded-lg transition-colors shadow-md"
            style={`background-color: ${headerLightBlue};`}
            onmouseover={`this.style.backgroundColor='${headerDarkBlue}'`}
            onmouseout={`this.style.backgroundColor='${headerLightBlue}'`}
          >
            {cta}
          </a>
        </div>
      ))}
    </div>

    </Container>
</section>
