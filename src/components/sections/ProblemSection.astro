---
import Container from '../ui/Container.astro';
import { t, tArray } from '../../i18n/ui';
import type { Locale } from '../../i18n/types';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;

// Translations
const title = await t(locale, 'problem.title');
const points = await tArray(locale, 'problem.points');
---

<section class="py-16 bg-primary">
  <Container>

    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">
        {title}
      </h2>
      <p class="text-xl text-white/70 max-w-2xl mx-auto">
        <!-- Optional subtitle? If needed, we can add one in i18n -->
      </p>
    </div>

    <!-- Problems Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-12">

      <!-- Problem 1 -->
      <div class="text-center">
        <div class="w-12 h-12 rounded-full bg-primary/60 flex items-center justify-center mx-auto mb-4 border border-white/10">
          <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-white mb-2">
          {points[0]}
        </h3>
      </div>

      <!-- Problem 2 -->
      <div class="text-center">
        <div class="w-12 h-12 rounded-full bg-primary/60 flex items-center justify-center mx-auto mb-4 border border-white/10">
          <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-white mb-2">
          {points[1]}
        </h3>
      </div>

      <!-- Problem 3 -->
      <div class="text-center">
        <div class="w-12 h-12 rounded-full bg-primary/60 flex items-center justify-center mx-auto mb-4 border border-white/10">
          <svg class="w-6 h-6 text-secondary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-white mb-2">
          {points[2]}
        </h3>
      </div>

    </div>

  </Container>
</section>
