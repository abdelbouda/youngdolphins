---
import Container from '../ui/Container.astro';
import { t } from '../../i18n/ui';
import type { Locale } from '../../i18n/types';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;

const title = await t(locale, 'team.title');
const subtitle = await t(locale, 'team.subtitle');
---

<section id="team" class="py-16 bg-primary">
  <Container>

    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">
        {title}
      </h2>

      <p class="text-xl text-white/70 max-w-2xl mx-auto">
        {subtitle}
      </p>
    </div>

    <!-- Team Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16 max-w-4xl mx-auto">

      <!-- Instructor 1 -->
      <div class="text-center">
        <div class="w-20 h-20 bg-secondary/20 rounded-full flex items-center justify-center text-secondary text-xl font-bold mx-auto mb-4">
          LK
        </div>

        <h3 class="text-lg font-semibold text-white mb-1">Lara Koster</h3>
        <p class="text-white/70 text-sm mb-3">Hoofd Instructeur</p>
        <p class="text-white/70 text-sm leading-relaxed">
          12+ jaar ervaring met zwemonderwijs. Gespecialiseerd in kinderen met watervrees en A/B/C‑diploma trajecten.
        </p>
      </div>

      <!-- Instructor 2 -->
      <div class="text-center">
        <div class="w-20 h-20 bg-secondary/20 rounded-full flex items-center justify-center text-secondary text-xl font-bold mx-auto mb-4">
          JM
        </div>

        <h3 class="text-lg font-semibold text-white mb-1">Jeroen Meijer</h3>
        <p class="text-white/70 text-sm mb-3">Baby & Peuter Specialist</p>
        <p class="text-white/70 text-sm leading-relaxed">
          Expert in ouder‑kind lessen. Zorgt voor een veilige, speelse introductie tot water voor de allerkleinsten.
        </p>
      </div>

      <!-- Instructor 3 -->
      <div class="text-center">
        <div class="w-20 h-20 bg-secondary/20 rounded-full flex items-center justify-center text-secondary text-xl font-bold mx-auto mb-4">
          SR
        </div>

        <h3 class="text-lg font-semibold text-white mb-1">Sofia Ramos</h3>
        <p class="text-white/70 text-sm mb-3">Privéles Coach</p>
        <p class="text-white/70 text-sm leading-relaxed">
          Bekend om haar geduld en persoonlijke aanpak. Helpt kinderen versneld hun diploma’s behalen.
        </p>
      </div>

    </div>

    <!-- Values -->
    <div class="max-w-3xl mx-auto mb-16">
      <h3 class="text-2xl font-semibold text-white text-center mb-8">
        Our values
      </h3>

      <div class="space-y-6">

        <div class="text-center border-b border-white/10 pb-6">
          <h4 class="text-lg font-semibold text-white mb-2">Safety First</h4>
          <p class="text-white/70 text-sm">
            Veiligheid staat altijd voorop. Onze instructeurs zijn volledig gecertificeerd en getraind in kindvriendelijke methodes.
          </p>
        </div>

        <div class="text-center border-b border-white/10 pb-6">
          <h4 class="text-lg font-semibold text-white mb-2">Fun & Confidence</h4>
          <p class="text-white/70 text-sm">
            Kinderen leren het snelst wanneer ze plezier hebben. We bouwen vertrouwen op in elke stap.
          </p>
        </div>

        <div class="text-center pb-6">
          <h4 class="text-lg font-semibold text-white mb-2">Personal Attention</h4>
          <p class="text-white/70 text-sm">
            Kleine groepen en persoonlijke begeleiding zorgen voor maximale vooruitgang.
          </p>
        </div>

      </div>
    </div>

    <!-- Join the Team -->
    <div class="text-center">
      <h3 class="text-2xl font-semibold text-white mb-4">
        Want to join us?
      </h3>
      <p class="text-white/70 mb-6 max-w-2xl mx-auto">
        We’re always looking for passionate instructors who love helping children grow in the water.
      </p>

      <a href="/careers" class="inline-flex items-center px-6 py-3 bg-secondary text-primary hover:bg-secondary/90 transition-colors font-semibold rounded">
        View open positions
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>

  </Container>
</section>
