---
import Container from '../ui/Container.astro';
import { tObject, t } from '../../i18n/utils';
import type { Locale } from '../../i18n/types';

interface Props {
  locale?: Locale;
}

const { locale = 'nl' } = Astro.props;

const title = await t(locale, 'team.title');
const subtitle = await t(locale, 'team.subtitle');
const values = await tObject(locale, 'values.items');
const valuesTitle = await t(locale, 'values.title');
const joinTitle = await t(locale, 'join.title');
const joinSubtitle = await t(locale, 'join.subtitle');
const joinCTA = await t(locale, 'join.cta');

// Haal de specifieke instructeurs data op uit de JSON
const teamData = await tObject(locale, 'team.instructors');
---

<section id="team" class="py-16 bg-primary">
  <Container>

    <div class="text-center mb-12">
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">
        {title}
      </h2>

      <p class="text-xl text-white/70 max-w-2xl mx-auto">
        {subtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16 max-w-5xl mx-auto">

      <div class="text-center">
        <div class="w-20 h-20 bg-secondary/20 rounded-full flex items-center justify-center text-secondary text-xl font-bold mx-auto mb-4">
          NB
        </div>
        <h3 class="text-lg font-semibold text-white mb-1">{teamData?.noureddine?.name || 'Noureddine Bouda'}</h3>
        <p class="text-white/70 text-sm mb-3 font-medium uppercase tracking-wider">{teamData?.noureddine?.role}</p>
        <p class="text-white/70 text-sm leading-relaxed px-4">
          {teamData?.noureddine?.bio}
        </p>
      </div>

      <div class="text-center">
        <div class="w-20 h-20 bg-secondary/20 rounded-full flex items-center justify-center text-secondary text-xl font-bold mx-auto mb-4">
          N
        </div>
        <h3 class="text-lg font-semibold text-white mb-1">{teamData?.nasredine?.name || 'Nasredine'}</h3>
        <p class="text-white/70 text-sm mb-3 font-medium uppercase tracking-wider">{teamData?.nasredine?.role}</p>
        <p class="text-white/70 text-sm leading-relaxed px-4">
          {teamData?.nasredine?.bio}
        </p>
      </div>

      <div class="text-center">
        <div class="w-20 h-20 bg-secondary/20 rounded-full flex items-center justify-center text-secondary text-xl font-bold mx-auto mb-4">
          SR
        </div>
        <h3 class="text-lg font-semibold text-white mb-1">Sofia Ramos</h3>
        <p class="text-white/70 text-sm mb-3 font-medium uppercase tracking-wider">{locale === 'nl' ? 'Privéles Coach' : 'Private Lesson Coach'}</p>
        <p class="text-white/70 text-sm leading-relaxed px-4">
          {locale === 'nl'
            ? 'Bekend om haar geduld en persoonlijke aanpak. Helpt kinderen versneld hun diploma’s behalen.'
            : 'Known for her patience and personal approach. Helps children earn their diplomas faster.'}
        </p>
      </div>

    </div>

    <div class="max-w-3xl mx-auto mb-16">
      <h3 class="text-2xl font-semibold text-white text-center mb-8">
        {valuesTitle}
      </h3>

      <div class="space-y-6">
        {Array.isArray(values) &&
          values.map((item) => (
            <div class="text-center border-b border-white/10 pb-6">
              <h4 class="text-lg font-semibold text-white mb-2">{item.title}</h4>
              <p class="text-white/70 text-sm">{item.description}</p>
            </div>
          ))}
      </div>
    </div>

    <div class="text-center">
      <h3 class="text-2xl font-semibold text-white mb-4">
        {joinTitle}
      </h3>

      <p class="text-white/70 mb-6 max-w-2xl mx-auto">
        {joinSubtitle}
      </p>

      <a href="https://wa.me/31628421354" class="inline-flex items-center px-6 py-3 bg-secondary text-primary hover:bg-secondary/90 transition-colors font-semibold rounded shadow-lg">
        {joinCTA}
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>

  </Container>
</section>
