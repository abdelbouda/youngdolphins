---
import Container from '../ui/Container.astro';
import { tObject, t } from '../../i18n/ui';
import type { Locale } from '../../i18n/types';

interface Props {
  locale?: Locale;
}

const { locale = 'en' } = Astro.props;

const title = await t(locale, 'team.title');
const subtitle = await t(locale, 'team.subtitle');
const values = await tObject(locale, 'values.items');
const valuesTitle = await t(locale, 'values.title');
const joinTitle = await t(locale, 'join.title');
const joinSubtitle = await t(locale, 'join.subtitle');
const joinCTA = await t(locale, 'join.cta');
---

<section id="team" class="py-16 bg-primary">
  <Container>

    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">
        {title}
      </h2>

      <p class="text-xl text-white/70 max-w-2xl mx-auto">
        {subtitle}
      </p>
    </div>

    <!-- Team Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16 max-w-4xl mx-auto">

      <!-- Instructor 1 -->
      <div class="text-center">
        <div class="w-20 h-20 bg-secondary/20 rounded-full flex items-center justify-center text-secondary text-xl font-bold mx-auto mb-4">
          LK
        </div>

        <h3 class="text-lg font-semibold text-white mb-1">Noureddine Bouda</h3>
        <p class="text-white/70 text-sm mb-3">{locale === 'nl' ? 'Hoofd Instructeur' : 'Head Instructor'}</p>
        <p class="text-white/70 text-sm leading-relaxed">
          {locale === 'nl'
            ? '12+ jaar ervaring met zwemonderwijs. Gespecialiseerd in kinderen met watervrees en A/B/C‑diploma trajecten.'
            : '12+ years of experience in swim education. Specialized in children with water anxiety and A/B/C diploma programs.'}
        </p>
      </div>

      <!-- Instructor 2 -->
      <div class="text-center">
        <div class="w-20 h-20 bg-secondary/20 rounded-full flex items-center justify-center text-secondary text-xl font-bold mx-auto mb-4">
          JM
        </div>

        <h3 class="text-lg font-semibold text-white mb-1">Nasredine</h3>
        <p class="text-white/70 text-sm mb-3">{locale === 'nl' ? 'Baby & Peuter Specialist' : 'Baby & Toddler Specialist'}</p>
        <p class="text-white/70 text-sm leading-relaxed">
          {locale === 'nl'
            ? 'Expert in ouder‑kind lessen. Zorgt voor een veilige, speelse introductie tot water voor de allerkleinsten.'
            : 'Expert in parent‑child lessons. Ensures a safe, playful introduction to water for the youngest swimmers.'}
        </p>
      </div>

      <!-- Instructor 3 -->
      <div class="text-center">
        <div class="w-20 h-20 bg-secondary/20 rounded-full flex items-center justify-center text-secondary text-xl font-bold mx-auto mb-4">
          SR
        </div>

        <h3 class="text-lg font-semibold text-white mb-1">Sofia Ramos</h3>
        <p class="text-white/70 text-sm mb-3">{locale === 'nl' ? 'Privéles Coach' : 'Private Lesson Coach'}</p>
        <p class="text-white/70 text-sm leading-relaxed">
          {locale === 'nl'
            ? 'Bekend om haar geduld en persoonlijke aanpak. Helpt kinderen versneld hun diploma’s behalen.'
            : 'Known for her patience and personal approach. Helps children earn their diplomas faster.'}
        </p>
      </div>

    </div>

    <!-- Values (dynamic i18n) -->
    <div class="max-w-3xl mx-auto mb-16">
      <h3 class="text-2xl font-semibold text-white text-center mb-8">
        {valuesTitle}
      </h3>

      <div class="space-y-6">
        {Array.isArray(values) &&
          values.map((item) => (
            <div class="text-center border-b border-white/10 pb-6">
              <h4 class="text-lg font-semibold text-white mb-2">{item.title}</h4>
              <p class="text-white/70 text-sm">{item.description}</p>
            </div>
          ))}
      </div>
    </div>

    <!-- Join the Team -->
    <div class="text-center">
      <h3 class="text-2xl font-semibold text-white mb-4">
        {joinTitle}
      </h3>

      <p class="text-white/70 mb-6 max-w-2xl mx-auto">
        {joinSubtitle}
      </p>

      <a href="/careers" class="inline-flex items-center px-6 py-3 bg-secondary text-primary hover:bg-secondary/90 transition-colors font-semibold rounded">
        {joinCTA}
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>

  </Container>
</section>
