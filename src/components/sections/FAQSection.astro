---
import Container from '../ui/Container.astro';
import { t, tObject } from '../../i18n/ui';
import type { Locale } from '../../i18n/types';

interface Props {
  locale?: Locale;
}

const { locale = 'nl' } = Astro.props;

// i18n
const title = await t(locale, 'faq.title');
const subtitle = await t(locale, 'faq.subtitle');
const items = await tObject(locale, 'faq.items'); // array of { question, answer }
---

<section id="faq" class="py-24 bg-white">
  <Container>

    <!-- Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl sm:text-4xl font-bold text-[#001F3F] mb-4">
        {title}
      </h2>
      <p class="text-gray-600 max-w-2xl mx-auto">
        {subtitle}
      </p>
    </div>

    <!-- FAQ List -->
    <div class="max-w-3xl mx-auto space-y-6">

      {items.map((item, index) => (
        <div class="border border-[#E1EEF7] rounded-xl p-6 bg-[#F7FBFF] shadow-sm">
          <button 
            class="w-full flex items-center justify-between text-left group"
            onclick={`toggleFAQ('faq-${index}')`}
          >
            <span class="text-lg font-semibold text-[#001F3F] group-hover:text-[#00AEEF] transition-colors">
              {item.question}
            </span>

            <svg id={`faq-${index}-icon`} 
                 class="w-5 h-5 text-gray-500 transform transition-transform ml-4"
                 fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                    d="M19 9l-7 7-7-7"/>
            </svg>
          </button>

          <div id={`faq-${index}`} class="hidden mt-4">
            <p class="text-gray-700 leading-relaxed">
              {item.answer}
            </p>
          </div>
        </div>
      ))}

    </div>

    <!-- Still have questions -->
    <div class="text-center mt-16">
      <h3 class="text-2xl font-semibold text-[#001F3F] mb-4">
        {await t(locale, 'faq.more_title')}
      </h3>

      <p class="text-lg text-gray-600 mb-6">
        {await t(locale, 'faq.more_subtitle')}
      </p>

      <a 
        href="/contact" 
        class="inline-flex items-center px-6 py-3 bg-[#001F3F] text-white hover:bg-[#00306A] transition-colors font-semibold rounded-lg"
      >
        {await t(locale, 'faq.more_cta')}
        <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
                d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      </a>
    </div>

  </Container>
</section>

<script>
  declare global {
    interface Window {
      toggleFAQ: (id: string) => void;
    }
  }

  window.toggleFAQ = function(id) {
    const content = document.getElementById(id);
    const icon = document.getElementById(id + '-icon');

    if (content && icon) {
      content.classList.toggle('hidden');
      icon.classList.toggle('rotate-180');
    }
  }
</script>
