---
const locale = Astro.currentLocale ?? 'nl';
const targetLocale = locale === 'nl' ? 'en' : 'nl';
const targetLabel = locale === 'nl' ? 'English' : 'Nederlands';

// Preserve current path and hash when switching language
const currentPath = Astro.url.pathname.replace(/^\/(nl|en)/, '') || '/';
const currentHash = Astro.url.hash;
const targetUrl = `/${targetLocale}${currentPath}${currentHash}`;

const nlFlag = `<svg viewBox="0 0 60 30" xmlns="http://www.w3.org/2000/svg" style="width:22px;height:15px;border-radius:2px;display:block;flex-shrink:0;"><rect width="60" height="30" fill="#AE1C28"/><rect width="60" height="20" y="10" fill="#FFF"/><rect width="60" height="10" y="20" fill="#21468B"/></svg>`;
const enFlag = `<svg viewBox="0 0 60 30" xmlns="http://www.w3.org/2000/svg" style="width:22px;height:15px;border-radius:2px;display:block;flex-shrink:0;"><clipPath id="uk2"><path d="M0 0v30h60V0z"/></clipPath><path fill="#012169" d="M0 0v30h60V0z"/><path stroke="#FFF" stroke-width="6" d="M0 0l60 30m0-30L0 30" clip-path="url(#uk2)"/><path stroke="#C8102E" stroke-width="4" d="M0 0l60 30m0-30L0 30" clip-path="url(#uk2)"/><path stroke="#FFF" stroke-width="10" d="M30 0v30M0 15h60"/><path stroke="#C8102E" stroke-width="6" d="M30 0v30M0 15h60"/></svg>`;

const currentFlag = locale === 'nl' ? nlFlag : enFlag;
const targetFlag = locale === 'nl' ? enFlag : nlFlag;
---

<div class="lang-switcher" data-lang-switcher style="position:relative;">
  <button
    type="button"
    class="lang-toggle"
    aria-haspopup="true"
    aria-expanded="false"
    style="display:flex;align-items:center;justify-content:center;gap:0.4rem;background-color:#001F3F;color:#ffffff;border:0;cursor:pointer;padding:0.5rem 0.75rem;border-radius:0.375rem;min-height:44px;"
  >
    <span aria-hidden="true" set:html={currentFlag}></span>
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="width:0.75rem;height:0.75rem;opacity:0.8;">
      <path d="M6 9l6 6 6-6"/>
    </svg>
    <span style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0);">Taal wisselen</span>
  </button>

  <ul class="lang-menu" role="menu" aria-label="Taalkeuze" style="display:none;position:absolute;right:0;margin-top:0.5rem;background:white;border-radius:0.5rem;box-shadow:0 6px 18px rgba(0,0,0,0.12);padding:0.25rem;list-style:none;z-index:60;min-width:150px;">
    <li role="none">
      <a role="menuitem" href={targetUrl} style="display:flex;align-items:center;gap:0.6rem;padding:0.5rem 0.75rem;text-decoration:none;color:#001F3F;border-radius:0.375rem;font-size:0.875rem;font-weight:500;">
        <span aria-hidden="true" set:html={targetFlag}></span>
        <span>{targetLabel}</span>
      </a>
    </li>
  </ul>
</div>

<script type="module">
  function initLangSwitchers() {
    document.querySelectorAll('[data-lang-switcher]').forEach(root => {
      if (root.dataset.initialized) return;
      root.dataset.initialized = 'true';

      const toggle = root.querySelector('.lang-toggle');
      const menu = root.querySelector('.lang-menu');
      if (!toggle || !menu) return;

      toggle.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = menu.style.display !== 'none';
        menu.style.display = isOpen ? 'none' : 'block';
        toggle.setAttribute('aria-expanded', String(!isOpen));
      });

      document.addEventListener('click', (e) => {
        if (!root.contains(e.target)) {
          menu.style.display = 'none';
          toggle.setAttribute('aria-expanded', 'false');
        }
      });

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          menu.style.display = 'none';
          toggle.setAttribute('aria-expanded', 'false');
        }
      });
    });
  }

  if (document.readyState !== 'loading') {
    initLangSwitchers();
  } else {
    document.addEventListener('DOMContentLoaded', initLangSwitchers);
  }
  document.addEventListener('astro:page-load', initLangSwitchers);
</script>
