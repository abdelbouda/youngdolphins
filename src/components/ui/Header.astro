---
import { preloadTranslations, tSync } from '../../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import logo from '../../assets/logo.webp';

const locale = Astro.currentLocale;
await preloadTranslations(locale);

// Navigatie-items centraal gedefinieerd (minder duplicatie)
const navItems = [
  { href: '/', key: 'nav.home' },
  { href: '/#features', key: 'nav.lessons' },
  { href: '/#pricing', key: 'nav.pricing' },
  { href: '/#faq', key: 'nav.faq' },
];
---

<header class="fixed top-0 left-0 w-full z-50 bg-white/80 backdrop-blur border-b border-gray-200">
  <nav class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3">
      <img 
        src={logo.src} 
        alt="Young Dolphins logo" 
        class="h-10 w-auto"
      />
      <span class="text-xl font-semibold text-[#001F3F]">Young Dolphins</span>
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden md:flex items-center gap-8 text-sm font-medium">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class="text-gray-700 hover:text-[#001F3F] transition-colors"
        >
          {tSync(locale, item.key)}
        </a>
      ))}

      <LanguageSwitcher />
    </div>

    <!-- Mobile Menu Button -->
    <button 
      id="mobile-menu-toggle"
      class="md:hidden text-gray-700 hover:text-[#001F3F] transition-colors text-2xl leading-none"
      aria-label="Open mobile menu"
    >
      ☰
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div 
    id="mobile-menu" 
    class="hidden md:hidden bg-white border-t border-gray-200 transition-all duration-300"
  >
    <div class="flex flex-col px-6 py-4 gap-4 text-sm font-medium">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class="text-gray-700 hover:text-[#001F3F] transition-colors"
        >
          {tSync(locale, item.key)}
        </a>
      ))}

      <LanguageSwitcher />
    </div>
  </div>

  <script>
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');

    toggle.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  </script>
</header>
