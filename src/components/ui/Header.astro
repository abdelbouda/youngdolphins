---
import { preloadTranslations, tSync } from '../../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getRelativeLocaleUrl } from 'astro:i18n';

const locale = Astro.currentLocale ?? 'nl';
await preloadTranslations(locale);

/**
 * MENU LOGICA:
 * We gebruiken getRelativeLocaleUrl om te zorgen dat de ankerlinks (#)
 * op de juiste taalpagina blijven (bijv. /en#pricing).
 */
const navItems = [
  { href: `/${locale}/`, key: 'nav.home' },
  { href: `/${locale}/#features`, key: 'nav.lessons' },
  { href: `/${locale}/#pricing`, key: 'nav.pricing' },
  { href: `/${locale}/#faq`, key: 'nav.contact' }
];

// De aanmeld-slug is voor beide talen nu /aanmelden binnen de taalfolder
const registerHref = locale === 'nl' ? 'https://www.youngdolphins.nl/nl/aanmelden/' : getRelativeLocaleUrl(locale, 'aanmelden');

const labels = {
  directRegister: locale === 'en' ? 'Register Now' : 'Direct Aanmelden',
  directContact: locale === 'en' ? 'Direct Contact' : 'Direct Contact',
  emailUs: locale === 'en' ? 'Email us' : 'Email ons'
};
---

<header id="site-header" style="background-color: #E6F4FF; border-bottom: 1px solid #e5e7eb;" class="fixed top-0 left-0 w-full z-50 backdrop-blur transition-all duration-300">
  <nav class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">

    <a href={`/${locale}/`} id="header-logo" class="flex items-center flex-shrink-0" style="color: inherit;">
      <img src="/yd-logo.webp" alt="Young Dolphins logo" width="180" height="180" fetchpriority="high" style="height: 80px; width: auto; object-fit: contain;" />
    </a>

    <div class="flex items-center gap-2 md:hidden ml-auto">
      <div class="relative">
        <LanguageSwitcher />
      </div>
      <a href="https://wa.me/31628421354" title={labels.directContact} style="background-color:#25D366;color:#ffffff;display:flex;align-items:center;justify-content:center;width:2.5rem;height:2.5rem;border-radius:9999px;">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" fill="currentColor" style="width:1.25rem;height:1.25rem;">
          <path d="M24 4C13 4 4 13 4 24c0 3.6 1 7 2.7 9.9L4 44l10.4-2.7C17.2 43 20.5 44 24 44c11 0 20-9 20-20S35 4 24 4zm0 36c-3.1 0-6.1-.8-8.7-2.4l-.6-.4-6.2 1.6 1.6-6-.4-.6C8.8 30.1 8 27.1 8 24 8 15.2 15.2 8 24 8s16 7.2 16 16-7.2 16-16 16zm8.8-11.8c-.5-.2-2.8-1.4-3.2-1.5-.4-.2-.7-.2-1 .2-.3.4-1.1 1.5-1.4 1.8-.3.3-.5.4-1 .1-.5-.2-2-.7-3.8-2.3-1.4-1.2-2.3-2.8-2.6-3.2-.3-.5 0-.7.2-1 .2-.2.5-.5.7-.8.2-.3.3-.5.4-.8.1-.3 0-.6-.1-.8-.1-.2-1-2.5-1.4-3.4-.4-.9-.7-.8-1-.8h-.9c-.3 0-.8.1-1.2.6-.4.5-1.6 1.6-1.6 3.8 0 2.2 1.6 4.4 1.9 4.7.3.3 3.2 4.8 7.7 6.7 1.1.5 1.9.7 2.6.9 1.1.3 2.1.3 2.9.2.9-.1 2.8-1.1 3.2-2.2.4-1.1.4-2 .3-2.2-.2-.3-.5-.4-1-.6z"/>
        </svg>
      </a>
      <button id="mobile-menu-toggle" style="color:#001F3F;display:flex;align-items:center;justify-content:center;width:2.5rem;height:2.5rem;border-radius:9999px;background:transparent;" aria-label="Menu openen">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="width:1.5rem;height:1.5rem;">
          <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>

    <div class="desktop-nav items-center gap-2 text-sm font-medium ml-auto">
      {navItems.map(item => (
        <a href={item.href} style="background-color:#001F3F;color:#ffffff;padding:0.5rem 0.75rem;border-radius:0.375rem;font-weight:500;text-decoration:none;">
          {item.label ? item.label : tSync(locale, item.key)}
        </a>
      ))}
      
      <div class="relative mx-1">
        <LanguageSwitcher />
      </div>

      <a href={registerHref} style="background-color:#00AEEF;color:#ffffff;padding:0.5rem 0.75rem;border-radius:0.375rem;font-weight:600;display:flex;align-items:center;gap:0.4rem;text-decoration:none;">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:1rem;height:1rem;flex-shrink:0;">
          <path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/>
        </svg>
        {labels.directRegister}
      </a>

      <a href="https://wa.me/31628421354" target="_blank" style="background-color:#25D366;color:#ffffff;padding:0.5rem 0.75rem;border-radius:0.375rem;font-weight:500;display:flex;align-items:center;gap:0.4rem;text-decoration:none;">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" fill="currentColor" style="width:1.1rem;height:1.1rem;flex-shrink:0;">
          <path d="M24 4C13 4 4 13 4 24c0 3.6 1 7 2.7 9.9L4 44l10.4-2.7C17.2 43 20.5 44 24 44c11 0 20-9 20-20S35 4 24 4zm0 36c-3.1 0-6.1-.8-8.7-2.4l-.6-.4-6.2 1.6 1.6-6-.4-.6C8.8 30.1 8 27.1 8 24 8 15.2 15.2 8 24 8s16 7.2 16 16-7.2 16-16 16zm8.8-11.8c-.5-.2-2.8-1.4-3.2-1.5-.4-.2-.7-.2-1 .2-.3.4-1.1 1.5-1.4 1.8-.3.3-.5.4-1 .1-.5-.2-2-.7-3.8-2.3-1.4-1.2-2.3-2.8-2.6-3.2-.3-.5 0-.7.2-1 .2-.2.5-.5.7-.8.2-.3.3-.5.4-.8.1-.3 0-.6-.1-.8-.1-.2-1-2.5-1.4-3.4-.4-.9-.7-.8-1-.8h-.9c-.3 0-.8.1-1.2.6-.4.5-1.6 1.6-1.6 3.8 0 2.2 1.6 4.4 1.9 4.7.3.3 3.2 4.8 7.7 6.7 1.1.5 1.9.7 2.6.9 1.1.3 2.1.3 2.9.2.9-.1 2.8-1.1 3.2-2.2.4-1.1.4-2 .3-2.2-.2-.3-.5-.4-1-.6z"/>
        </svg>
        {labels.directContact}
      </a>

      <a href="mailto:info@youngdolphins.nl" style="background-color:#001F3F;color:#ffffff;padding:0.5rem 0.75rem;border-radius:0.375rem;font-weight:500;display:flex;align-items:center;gap:0.4rem;text-decoration:none;">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:1rem;height:1rem;flex-shrink:0;">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 6-4-4v14a2 2 0 01-2 2h-14a2 2 0 01-2-2v14a2 2 0 012 2h14a2 2 0 012-2v-14a2 2 0 01-2-2z"/>
        </svg>
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:1rem;height:1rem;">
          <rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 7l10 7 10-7"/>
        </svg>
        {labels.emailUs}
      </a>
    </div>
  </nav>

  <div id="mobile-overlay" class="fixed inset-0 bg-black/40 opacity-0 pointer-events-none transition-opacity duration-300 md:hidden z-40"></div>

  <aside id="mobile-menu" class="fixed top-0 right-0 h-screen w-72 bg-white shadow-xl border-l border-gray-200 transform translate-x-full transition-transform duration-300 ease-in-out md:hidden z-50">
    <div class="flex items-center justify-between px-4 py-4 border-b">
      <div class="flex items-center gap-3">
        <img src="/yd-logo.webp" alt="Young Dolphins logo" width="120" height="120" style="height: 40px; width: auto; object-fit: contain;" />
        <span class="text-lg font-semibold" style="color:#001F3F;">Menu</span>
      </div>
      <button id="mobile-menu-close" style="color:#001F3F;display:flex;align-items:center;justify-content:center;width:2.25rem;height:2.25rem;border-radius:9999px;background:transparent;" aria-label="Menu sluiten">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="width:1.25rem;height:1.25rem;">
          <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div class="flex flex-col px-4 py-6 gap-3">
      {navItems.map(item => (
        <a href={item.href} style="background-color:#001F3F;color:#ffffff;padding:0.75rem 1rem;border-radius:0.5rem;font-weight:500;font-size:1rem;display:flex;align-items:center;text-decoration:none;">
          {item.label ? item.label : tSync(locale, item.key)}
        </a>
      ))}
      <a href={registerHref} style="background-color:#00AEEF;color:#ffffff;padding:0.75rem 1rem;border-radius:0.5rem;font-weight:600;font-size:1rem;display:flex;align-items:center;gap:0.625rem;text-decoration:none;">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width:1.2rem;height:1.2rem;flex-shrink:0;">
          <path d="M16 21v-2a4 4 0 00-4-4H6a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/>
        </svg>
        {labels.directRegister}
      </a>
      <a href="https://wa.me/31628421354" target="_blank" style="background-color:#25D366;color:#ffffff;padding:0.75rem 1rem;border-radius:0.5rem;font-weight:600;font-size:1rem;display:flex;align-items:center;gap:0.625rem;margin-top:0.5rem;text-decoration:none;">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" fill="currentColor" style="width:1.25rem;height:1.25rem;flex-shrink:0;">
          <path d="M24 4C13 4 4 13 4 24c0 3.6 1 7 2.7 9.9L4 44l10.4-2.7C17.2 43 20.5 44 24 44c11 0 20-9 20-20S35 4 24 4zm0 36c-3.1 0-6.1-.8-8.7-2.4l-.6-.4-6.2 1.6 1.6-6-.4-.6C8.8 30.1 8 27.1 8 24 8 15.2 15.2 8 24 8s16 7.2 16 16-7.2 16-16 16zm8.8-11.8c-.5-.2-2.8-1.4-3.2-1.5-.4-.2-.7-.2-1 .2-.3.4-1.1 1.5-1.4 1.8-.3.3-.5.4-1 .1-.5-.2-2-.7-3.8-2.3-1.4-1.2-2.3-2.8-2.6-3.2-.3-.5 0-.7.2-1 .2-.2.5-.5.7-.8.2-.3.3-.5.4-.8.1-.3 0-.6-.1-.8-.1-.2-1-2.5-1.4-3.4-.4-.9-.7-.8-1-.8h-.9c-.3 0-.8.1-1.2.6-.4.5-1.6 1.6-1.6 3.8 0 2.2 1.6 4.4 1.9 4.7.3.3 3.2 4.8 7.7 6.7 1.1.5 1.9.7 2.6.9 1.1.3 2.1.3 2.9.2.9-.1 2.8-1.1 3.2-2.2.4-1.1.4-2 .3-2.2-.2-.3-.5-.4-1-.6z"/>
        </svg>
        {labels.directContact}
      </a>
    </div>
  </aside>

  <script type="module">
    document.addEventListener('DOMContentLoaded', () => {
      const toggle = document.getElementById('mobile-menu-toggle');
      const menu = document.getElementById('mobile-menu');
      const overlay = document.getElementById('mobile-overlay');
      const closeBtn = document.getElementById('mobile-menu-close');

      function openMenu() {
        menu.classList.remove('translate-x-full');
        overlay.classList.remove('opacity-0', 'pointer-events-none');
        overlay.classList.add('opacity-100');
        document.body.style.overflow = 'hidden';
      }

      function closeMenu() {
        menu.classList.add('translate-x-full');
        overlay.classList.add('opacity-0', 'pointer-events-none');
        overlay.classList.remove('opacity-100');
        document.body.style.overflow = '';
      }

      toggle?.addEventListener('click', openMenu);
      closeBtn?.addEventListener('click', closeMenu);
      overlay?.addEventListener('click', closeMenu);

      menu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', closeMenu);
      });
    });
  </script>
</header>

<style>
  .desktop-nav {
    display: none;
  }
  @media (min-width: 1120px) { 
    .desktop-nav {
      display: flex;
    }
    #mobile-menu-toggle {
        display: none;
    }
  }
</style>
