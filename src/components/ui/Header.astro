---
import { preloadTranslations, tSync } from '../../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import logo from '../../assets/logo.webp';

const locale = Astro.currentLocale ?? 'nl';
await preloadTranslations(locale);

const navItems = [
  { href: '/', key: 'nav.home' },
  { href: '/#features', key: 'nav.lessons' },
  { href: '/#pricing', key: 'nav.pricing' },
  { href: '/#faq', label: 'FAQ' }
];
---

<header id="site-header" class="fixed top-0 left-0 w-full z-50 bg-white/90 backdrop-blur border-b border-gray-200 transition-all duration-300">
  <nav class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">

    <!-- LOGO -->
    <a href="/" id="header-logo" class="flex items-center flex-shrink-0">
      <img 
        src={logo.src} 
        alt="Young Dolphins logo" 
        class="h-10 sm:h-12 w-auto transition-all duration-300"
        style="aspect-ratio: 3.5 / 1; object-fit: contain;"
      />
    </a>

    <!-- MOBILE ACTIONS -->
    <div class="flex items-center gap-1 md:hidden ml-auto">

      <!-- WhatsApp -->
      <a href="https://wa.me/31628421354" title="WhatsApp"
        class="flex items-center justify-center w-10 h-10 bg-[#25D366] text-white rounded-full hover:bg-[#1ebe5d] transition-colors shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.67-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.076 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421-7.403h-.004a9.87 9.87 0 00-4.929 1.242l-.355.215-3.678.965.983-3.595-.233-.374A9.86 9.86 0 002.049 9.91C2.049 15.434 6.545 19.92 12.057 19.92h.005c2.686 0 5.212-.955 7.218-2.699.37-.331.649-.725.813-1.16.164-.436.21-.897.1-1.345a9.947 9.947 0 00-1.285-3.055 10.05 10.05 0 00-2.4-2.57c-.897-.634-1.958-.99-3.055-.99z"/>
        </svg>
      </a>

      <!-- Email -->
      <a href="mailto:info@youngdolphins.nl" title="Email"
        class="flex items-center justify-center w-10 h-10 bg-[#001F3F] text-white rounded-full hover:bg-[#003366] transition-colors shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="M2 7l10 7 10-7"/>
        </svg>
      </a>

      <!-- Language Switcher -->
      <div class="relative">
        <LanguageSwitcher client:load />
      </div>

      <!-- Hamburger -->
      <button id="mobile-menu-toggle"
        class="flex items-center justify-center w-10 h-10 text-[#001F3F] hover:bg-gray-100 rounded-full transition-colors"
        aria-label="Menu openen">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="w-6 h-6">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>

    <!-- DESKTOP NAV -->
    <div class="hidden md:flex items-center gap-3 text-sm font-medium ml-auto">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class="px-4 py-2 bg-[#001F3F] text-white rounded-md hover:bg-[#003366] transition-all shadow-sm"
        >
          {item.label ? item.label : tSync(locale, item.key)}
        </a>
      ))}

      <div class="relative">
        <LanguageSwitcher client:load />
      </div>

      <a href="https://wa.me/31628421354" class="px-4 py-2 bg-[#25D366] text-white rounded-md hover:bg-[#1ebe5d] transition-all flex items-center gap-2 shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.67-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.076 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421-7.403h-.004a9.87 9.87 0 00-4.929 1.242l-.355.215-3.678.965.983-3.595-.233-.374A9.86 9.86 0 002.049 9.91C2.049 15.434 6.545 19.92 12.057 19.92h.005c2.686 0 5.212-.955 7.218-2.699.37-.331.649-.725.813-1.16.164-.436.21-.897.1-1.345a9.947 9.947 0 00-1.285-3.055 10.05 10.05 0 00-2.4-2.57c-.897-.634-1.958-.99-3.055-.99z"/>
        </svg>
        Direct aanmelden
      </a>

      <a href="mailto:info@youngdolphins.nl" class="px-4 py-2 bg-[#001F3F] text-white rounded-md hover:bg-[#003366] transition-all flex items-center gap-2 shadow-sm">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="M2 7l10 7 10-7"/>
        </svg>
        Email ons
      </a>
    </div>
  </nav>

  <!-- OVERLAY -->
  <div id="mobile-overlay" class="fixed inset-0 bg-black/40 opacity-0 pointer-events-none transition-opacity duration-300 md:hidden z-40"></div>

  <!-- MOBILE MENU SIDEBAR -->
  <aside id="mobile-menu" class="fixed top-0 right-0 h-screen w-72 bg-white shadow-xl border-l border-gray-200 transform translate-x-full transition-transform duration-300 ease-in-out md:hidden z-50">
    <div class="flex items-center justify-between px-4 py-4 border-b">
      <span class="text-lg font-semibold text-[#001F3F]">Menu</span>
      <button id="mobile-menu-close" class="flex items-center justify-center w-9 h-9 text-[#001F3F] hover:bg-gray-100 rounded-full transition-colors" aria-label="Menu sluiten">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="w-5 h-5">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <div class="flex flex-col px-4 py-6 gap-3 text-sm font-medium">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class="flex items-center px-4 py-3 bg-[#001F3F] text-white rounded-lg hover:bg-[#003366] transition-all shadow-sm text-base"
        >
          {item.label ? item.label : tSync(locale, item.key)}
        </a>
      ))}
    </div>
  </aside>

  <script type="module">
    document.addEventListener('DOMContentLoaded', () => {
      const toggle = document.getElementById('mobile-menu-toggle');
      const menu = document.getElementById('mobile-menu');
      const overlay = document.getElementById('mobile-overlay');
      const closeBtn = document.getElementById('mobile-menu-close');

      function openMenu() {
        menu.classList.remove('translate-x-full');
        overlay.classList.remove('opacity-0', 'pointer-events-none');
        overlay.classList.add('opacity-100');
        document.body.style.overflow = 'hidden';
      }

      function closeMenu() {
        menu.classList.add('translate-x-full');
        overlay.classList.add('opacity-0', 'pointer-events-none');
        overlay.classList.remove('opacity-100');
        document.body.style.overflow = '';
      }

      toggle?.addEventListener('click', openMenu);
      closeBtn?.addEventListener('click', closeMenu);
      overlay?.addEventListener('click', closeMenu);

      menu?.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', closeMenu);
      });
    });
  </script>
</header>
