---
import { preloadTranslations, tSync } from '../../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import logo from '../../assets/logo.webp';

const locale = Astro.currentLocale;
await preloadTranslations(locale);

const navItems = [
  { href: '/', key: 'nav.home' },
  { href: '/#features', key: 'nav.lessons' },
  { href: '/#pricing', key: 'nav.pricing' },
  { href: '/#faq', label: 'FAQ' }
];
---

<header id="site-header" class="fixed top-0 left-0 w-full z-50 bg-white/90 backdrop-blur border-b border-gray-200 transition-all duration-300">
  <nav class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" id="header-logo" class="flex items-center flex-shrink-0">
      <img 
        src={logo.src} 
        alt="Young Dolphins logo" 
        class="h-10 sm:h-14 w-auto transition-all duration-300"
        style="aspect-ratio: 3.5 / 1; object-fit: contain;"
      />
    </a>

    <!-- MOBILE: CTA + Language + Hamburger -->
    <div class="flex items-center gap-3 md:hidden">

      <!-- WhatsApp -->
      <a 
        href="https://wa.me/31628421354" 
        class="px-3 py-2 bg-[#001F3F] text-white rounded-md text-sm font-semibold hover:bg-[#003366] transition"
      >
        WhatsApp
      </a>

      <!-- Email -->
      <a 
        href="mailto:info@youngdolphins.nl" 
        class="px-3 py-2 bg-[#001F3F] text-white rounded-md text-sm font-semibold hover:bg-[#003366] transition"
      >
        Email
      </a>

      <!-- Language Switcher -->
      <LanguageSwitcher />

      <!-- Hamburger -->
      <button 
        id="mobile-menu-toggle"
        class="text-[#001F3F] text-3xl leading-none"
        aria-label="Open mobile menu"
      >
        ☰
      </button>
    </div>

    <!-- DESKTOP NAVIGATION (ongewijzigd) -->
    <div class="hidden md:flex items-center gap-3 text-sm font-medium">

      {navItems.map(item => (
        <a 
          href={item.href} 
          class="px-4 py-2 bg-[#001F3F] text-white rounded-md hover:bg-[#003366] hover:scale-[1.03] transition-all shadow-sm"
        >
          {item.label ? item.label : tSync(locale, item.key)}
        </a>
      ))}

      <!-- Language Switcher -->
      <div class="relative">
        <LanguageSwitcher />
      </div>

      <!-- WhatsApp -->
      <a 
        href="https://wa.me/31628421354" 
        class="px-4 py-2 bg-[#001F3F] text-white rounded-md hover:bg-[#003366] transition-all shadow-sm"
      >
        Direct aanmelden
      </a>

      <!-- Email -->
      <a 
        href="mailto:info@youngdolphins.nl" 
        class="px-4 py-2 bg-[#001F3F] text-white rounded-md hover:bg-[#003366] transition-all shadow-sm"
      >
        Email ons
      </a>
    </div>
  </nav>

  <!-- OVERLAY -->
  <div 
    id="mobile-overlay"
    class="fixed inset-0 bg-black/40 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 md:hidden z-40"
  ></div>

  <!-- SLIDE-IN MOBILE MENU -->
  <div
    id="mobile-menu"
    class="fixed top-0 right-0 h-full w-64 bg-white shadow-xl border-l border-gray-200 transform translate-x-full transition-transform duration-300 ease-in-out md:hidden z-50"
  >
    <div class="flex flex-col px-6 py-8 gap-4 text-sm font-medium">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class="px-4 py-2 bg-[#001F3F] text-white rounded-md hover:bg-[#003366] transition-all shadow-sm"
        >
          {item.label ? item.label : tSync(locale, item.key)}
        </a>
      ))}
    </div>
  </div>

  <script>
    const header = document.getElementById('site-header');
    const logo = document.getElementById('header-logo');
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const overlay = document.getElementById('mobile-overlay');

    let isOpen = false;

    function openMenu() {
      isOpen = true;
      if (menu && overlay) {
        menu.classList.remove('translate-x-full');
        menu.classList.add('translate-x-0');
        overlay.classList.remove('opacity-0', 'pointer-events-none');
        overlay.classList.add('opacity-100');
      }
    }

    function closeMenu() {
      isOpen = false;
      if (menu && overlay) {
        menu.classList.remove('translate-x-0');
        menu.classList.add('translate-x-full');
        overlay.classList.add('opacity-0', 'pointer-events-none');
        overlay.classList.remove('opacity-100');
      }
    }

    if (toggle && menu && overlay) {
      toggle.addEventListener('click', () => {
        isOpen ? closeMenu() : openMenu();
      });

      overlay.addEventListener('click', closeMenu);
    }

    // Sticky shrink effect
    if (header && logo) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 20) {
          header.classList.add('py-1', 'bg-white/95');
          logo.classList.add('scale-90');
        } else {
          header.classList.remove('py-1', 'bg-white/95');
          logo.classList.remove('scale-90');
        }
      });
    }
  </script>
</header>
