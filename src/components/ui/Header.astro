---
import { tSync, preloadTranslations } from '../../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.tsx';
import logo from '../../assets/logo.webp';

const locale = Astro.currentLocale;

// Zorg dat translations geladen zijn vóór render
await preloadTranslations(locale);
---

<header class="fixed top-0 left-0 w-full z-50 bg-white/80 backdrop-blur border-b border-gray-200">
  <nav class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center gap-3">
      <img 
        src={logo.src} 
        alt="Young Dolphins logo" 
        class="h-10 w-auto"
      />
      <span class="text-xl font-semibold text-[#001F3F]">Young Dolphins</span>
    </a>

    <!-- Desktop Navigation -->
    <div class="hidden md:flex items-center gap-8 text-sm font-medium">
      <a href="/" class="text-gray-700 hover:text-[#001F3F] transition-colors">
        {tSync(locale, 'nav.home')}
      </a>
      <a href="/#features" class="text-gray-700 hover:text-[#001F3F] transition-colors">
        {tSync(locale, 'nav.lessons')}
      </a>
      <a href="/#pricing" class="text-gray-700 hover:text-[#001F3F] transition-colors">
        {tSync(locale, 'nav.pricing')}
      </a>
      <a href="/#faq" class="text-gray-700 hover:text-[#001F3F] transition-colors">
        {tSync(locale, 'nav.faq')}
      </a>

      <LanguageSwitcher />
    </div>

    <!-- Mobile Menu Button -->
    <button 
      id="mobile-menu-toggle"
      class="md:hidden text-gray-700 hover:text-[#001F3F] transition-colors"
    >
      ☰
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-gray-200">
    <div class="flex flex-col px-6 py-4 gap-4 text-sm font-medium">
      <a href="/" class="text-gray-700 hover:text-[#001F3F] transition-colors">
        {tSync(locale, 'nav.home')}
      </a>
      <a href="/#features" class="text-gray-700 hover:text-[#001F3F] transition-colors">
        {tSync(locale, 'nav.lessons')}
      </a>
      <a href="/#pricing" class="text-gray-700 hover:text-[#001F3F] transition-colors">
        {tSync(locale, 'nav.pricing')}
      </a>
      <a href="/#faq" class="text-gray-700 hover:text-[#001F3F] transition-colors">
        {tSync(locale, 'nav.faq')}
      </a>

      <LanguageSwitcher />
    </div>
  </div>

  <script>
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');

    toggle.addEventListener('click', () => {
      menu.classList.toggle('hidden');
    });
  </script>
</header>
