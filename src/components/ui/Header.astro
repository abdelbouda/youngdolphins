---
import { preloadTranslations, tSync } from '../../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import logo from '../../assets/logo.webp';

const locale = Astro.currentLocale;
await preloadTranslations(locale);

const navItems = [
  { href: '/', key: 'nav.home' },
  { href: '/#features', key: 'nav.lessons' },
  { href: '/#pricing', key: 'nav.pricing' },
  { href: '/#faq', label: 'FAQ' }
];
---

<header id="site-header" class="fixed top-0 left-0 w-full z-50 bg-white/90 backdrop-blur border-b border-gray-200 transition-all duration-300">
  <nav class="max-w-7xl mx-auto px-2 sm:px-4 py-1.5 flex flex-wrap items-center justify-between gap-y-2">

    <!-- Logo -->
    <a href="/" id="header-logo" class="flex items-center flex-shrink-0 transition-all duration-300">
      <img 
        src={logo.src} 
        alt="Young Dolphins logo" 
        class="h-18 w-auto sm:h-20 md:h-22 transition-all duration-300"
        style="aspect-ratio: 3.5 / 1; object-fit: contain;"
      />
    </a>

    <!-- Contact Buttons -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:gap-3">

      <!-- WhatsApp Button -->
      <a 
        href="https://wa.me/31628421354" 
        class="inline-flex items-center bg-[#001F3F] text-white font-semibold px-4 py-2 rounded-md hover:bg-[#003366] hover:scale-[1.03] active:scale-[0.98] transition-all duration-200 shadow-sm"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5 mr-2">
          <path d="M12 0C5.373 0 0 5.373 0 12c0 2.12.55 4.11 1.51 5.86L0 24l6.29-1.64A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22a9.94 9.94 0 01-5.09-1.39l-.36-.21-3.73.97.99-3.63-.24-.37A9.94 9.94 0 012 12C2 6.486 6.486 2 12 2s10 4.486 10 10-4.486 10-10 10zm5.07-7.93c-.27-.14-1.59-.78-1.84-.87-.25-.09-.43-.14-.61.14-.18.27-.7.87-.86 1.05-.16.18-.32.2-.59.07-.27-.14-1.14-.42-2.17-1.34-.8-.71-1.34-1.58-1.5-1.85-.16-.27-.02-.42.12-.56.12-.12.27-.32.41-.48.14-.16.18-.27.27-.45.09-.18.05-.34-.02-.48-.07-.14-.61-1.47-.84-2.02-.22-.53-.45-.46-.61-.47h-.52c-.18 0-.48.07-.73.34-.25.27-.96.94-.96 2.29s.98 2.65 1.12 2.83c.14.18 1.93 2.95 4.68 4.14.65.28 1.16.45 1.56.58.65.21 1.24.18 1.71.11.52-.08 1.59-.65 1.82-1.28.23-.63.23-1.17.16-1.28-.07-.11-.25-.18-.52-.32z"/>
        </svg>
        Direct aanmelden
      </a>

      <!-- Email Button -->
      <a 
        href="mailto:info@youngdolphins.nl" 
        class="inline-flex items-center bg-[#001F3F] text-white font-semibold px-4 py-2 rounded-md hover:bg-[#003366] hover:scale-[1.03] active:scale-[0.98] transition-all duration-200 shadow-sm mt-2 sm:mt-0"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24" class="w-5 h-5 mr-2">
          <path d="M12 13.065L.015 6h23.97L12 13.065zM0 8.235V18h24V8.235l-12 7.065L0 8.235z"/>
        </svg>
        Email ons
      </a>

    </div>

    <!-- Navigation + Language Switcher -->
    <div class="hidden md:flex items-center gap-2 text-sm font-medium">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class="inline-flex items-center bg-[#001F3F] text-white font-semibold px-4 py-2 rounded-md hover:bg-[#003366] hover:scale-[1.03] active:scale-[0.98] transition-all duration-200 shadow-sm"
        >
          {item.label ? item.label : tSync(locale, item.key)}
        </a>
      ))}

      <!-- SVG Dropdown Language Switcher -->
      <div class="relative">
        <LanguageSwitcher />
      </div>
    </div>

    <!-- Mobile Menu Button -->
    <button 
      id="mobile-menu-toggle"
      class="md:hidden text-[#001F3F] hover:text-[#00C2CB] transition-colors text-2xl leading-none"
      aria-label="Open mobile menu"
    >
      ☰
    </button>
  </nav>

  <!-- Mobile Menu -->
  <div 
    id="mobile-menu" 
    class="hidden md:hidden bg-white border-t border-gray-200 transition-all duration-300"
  >
    <div class="flex flex-col px-6 py-4 gap-4 text-sm font-medium">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class="inline-flex items-center bg-[#001F3F] text-white font-semibold px-4 py-2 rounded-md hover:bg-[#003366] hover:scale-[1.03] active:scale-[0.98] transition-all duration-200 shadow-sm"
        >
          {item.label ? item.label : tSync(locale, item.key)}
        </a>
      ))}

      <!-- Mobile Language Switcher -->
      <div class="relative">
        <LanguageSwitcher />
      </div>
    </div>
  </div>

  <script>
    const header = document.getElementById('site-header');
    const logo = document.getElementById('header-logo');

    window.addEventListener('scroll', () => {
      if (window.scrollY > 20) {
        header.classList.add('py-1');
        header.classList.add('bg-white/95');
        logo.classList.add('scale-90');
      } else {
        header.classList.remove('py-1');
        header.classList.remove('bg-white/95');
        logo.classList.remove('scale-90');
      }
    });

    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    toggle.addEventListener('click', () => menu.classList.toggle('hidden'));
  </script>
</header>
