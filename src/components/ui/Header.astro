---
import { preloadTranslations, tSync } from '../../i18n/utils';
import LanguageSwitcher from './LanguageSwitcher.astro';
import logo from '../../assets/logo.webp';

const locale = Astro.currentLocale ?? 'nl';
await preloadTranslations(locale);

const navItems = [
  { href: '/', key: 'nav.home' },
  { href: '/#features', key: 'nav.lessons' },
  { href: '/#pricing', key: 'nav.pricing' },
  { href: '/#faq', label: 'FAQ' }
];
---

<header id="site-header" class="fixed top-0 left-0 w-full z-50 bg-white/90 backdrop-blur border-b border-gray-200 transition-all duration-300">
  <nav class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" id="header-logo" class="flex items-center flex-shrink-0">
      <img 
        src={logo.src} 
        alt="Young Dolphins logo" 
        class="h-10 sm:h-14 w-auto transition-all duration-300"
        style="aspect-ratio: 3.5 / 1; object-fit: contain;"
      />
    </a>

    <!-- MOBILE ACTIONS -->
    <div class="flex items-center gap-2 md:hidden">

      <!-- WhatsApp -->
      <a href="https://wa.me/31628421354" class="p-2 bg-[#001F3F] text-white rounded-md">
        <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="w-5 h-5">
          <path d="M12 0C5.373 0 0 5.373 0 12c0 2.12.55 4.11 1.51 5.86L0 24l6.29-1.64A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/>
        </svg>
      </a>

      <!-- Email -->
      <a href="mailto:info@youngdolphins.nl" class="p-2 bg-[#001F3F] text-white rounded-md">
        <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" class="w-5 h-5">
          <path d="M12 13.065L.015 6h23.97L12 13.065z"/>
        </svg>
      </a>

      <!-- Language Switcher (ONE INSTANCE ONLY) -->
      <div class="relative">
        <LanguageSwitcher client:load />
      </div>

      <!-- Hamburger -->
      <button id="mobile-menu-toggle" class="text-[#001F3F] text-3xl p-1">
        ☰
      </button>
    </div>

    <!-- DESKTOP NAV -->
    <div class="hidden md:flex items-center gap-3 text-sm font-medium">

      {navItems.map(item => (
        <a 
          href={item.href} 
          class="px-4 py-2 bg-[#001F3F] text-white rounded-md hover:bg-[#003366] transition-all shadow-sm"
        >
          {item.label ? item.label : tSync(locale, item.key)}
        </a>
      ))}

      <!-- SAME LanguageSwitcher instance -->
      <div class="relative">
        <LanguageSwitcher client:load />
      </div>

      <a href="https://wa.me/31628421354" class="px-4 py-2 bg-[#001F3F] text-white rounded-md">
        Direct aanmelden
      </a>

      <a href="mailto:info@youngdolphins.nl" class="px-4 py-2 bg-[#001F3F] text-white rounded-md">
        Email ons
      </a>
    </div>
  </nav>

  <!-- OVERLAY -->
  <div id="mobile-overlay" class="fixed inset-0 bg-black/40 opacity-0 pointer-events-none transition-opacity duration-300 md:hidden z-40"></div>

  <!-- MOBILE MENU -->
  <aside id="mobile-menu" class="fixed top-0 right-0 h-full w-64 bg-white shadow-xl border-l border-gray-200 transform translate-x-full transition-transform duration-300 ease-in-out md:hidden z-50">
    <div class="flex items-center justify-between px-4 py-3 border-b">
      <div class="text-lg font-semibold text-[#001F3F]">Menu</div>
      <button id="mobile-menu-close" class="p-2 text-[#001F3F]">✕</button>
    </div>

    <div class="flex flex-col px-4 py-6 gap-3 text-sm font-medium">
      {navItems.map(item => (
        <a 
          href={item.href} 
          class="block px-4 py-2 bg-[#001F3F] text-white rounded-md hover:bg-[#003366] transition-all shadow-sm"
        >
          {item.label ? item.label : tSync(locale, item.key)}
        </a>
      ))}
    </div>
  </aside>

  <script type="module">
    document.addEventListener('DOMContentLoaded', () => {
      const toggle = document.getElementById('mobile-menu-toggle');
      const menu = document.getElementById('mobile-menu');
      const overlay = document.getElementById('mobile-overlay');
      const closeBtn = document.getElementById('mobile-menu-close');

      function openMenu() {
        menu.classList.remove('translate-x-full');
        overlay.classList.remove('opacity-0', 'pointer-events-none');
        overlay.classList.add('opacity-100');
        document.body.style.overflow = 'hidden';
      }

      function closeMenu() {
        menu.classList.add('translate-x-full');
        overlay.classList.add('opacity-0', 'pointer-events-none');
        overlay.classList.remove('opacity-100');
        document.body.style.overflow = '';
      }

      toggle.addEventListener('click', openMenu);
      closeBtn.addEventListener('click', closeMenu);
      overlay.addEventListener('click', closeMenu);
    });
  </script>
</header>
